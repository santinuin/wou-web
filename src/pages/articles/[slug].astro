---
// On-demand rendering: se renderiza cuando el usuario visita el artículo.
// Cloudflare cachea el resultado en el edge durante 30 días.
// Cuando WordPress actualiza un post, el webhook purga solo esa URL.
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import ArticleCard from '@/sections/article/ArticleCard.astro';
import NewsList from '@/components/content/NewsList.astro';
import CategoryNav from '@/sections/category/CategoryNav.astro';
import {
  fetchWpPostBySlug,
  fetchWpPostsByCategory,
  extractElementorContent,
} from '@/lib/cms/wordpress';

const { slug } = Astro.params;

if (!slug) return Astro.redirect('/404');

const post = await fetchWpPostBySlug(slug);

if (!post) return Astro.redirect('/404');

// Cache en Cloudflare Edge: 30 días (s-maxage).
// El browser no cachea (no-store) para que el purge del webhook sea efectivo.
Astro.response.headers.set(
  'Cache-Control',
  'public, no-store, s-maxage=2592000, stale-while-revalidate=86400'
);

const title = post.title.rendered;
const content = extractElementorContent(post.content.rendered);
const excerpt = post.excerpt.rendered.replace(/<[^>]+>/g, '').trim();
const featuredMedia = post._embedded?.['wp:featuredmedia']?.[0] ?? null;
const featuredImage = featuredMedia?.source_url ?? null;
const featuredImageAlt = featuredMedia?.alt_text ?? title;
const featuredImageWidth = featuredMedia?.media_details?.width ?? 1200;
const featuredImageHeight = featuredMedia?.media_details?.height ?? 675;
const categories = post._embedded?.['wp:term']?.[0] ?? [];

// Relacionados: hasta 4 artículos de la primera categoría, excluyendo este post.
const primaryCategory = categories[0] ?? null;
const relatedPosts = primaryCategory
  ? (await fetchWpPostsByCategory(primaryCategory.slug, 5))
      .filter((p) => p.slug !== post.slug)
      .slice(0, 4)
  : [];

const relatedArticles = relatedPosts.map((p) => ({
  title: p.title.rendered,
  publishedAt: p.date,
  slug: p.slug,
  href: `/articles/${p.slug}`,
  imageUrl: p._embedded?.['wp:featuredmedia']?.[0]?.source_url ?? null,
  excerpt: p.excerpt?.rendered?.replace(/<[^>]+>/g, '').trim() ?? null,
}));
---

<BaseLayout
  title={title}
  description={excerpt}
  ogImage={featuredImage ?? undefined}
  canonicalUrl={post.link}
>
  <Header slot="header" />

  <div class="ArticlePage">
    <div class="ArticlePage__container">
      <ArticleCard
        title={title}
        excerpt={excerpt}
        content={content}
        publishedAt={post.date}
        featuredImage={featuredImage}
        featuredImageAlt={featuredImageAlt}
        featuredImageWidth={featuredImageWidth}
        featuredImageHeight={featuredImageHeight}
        categories={categories.map((c) => ({ name: c.name, slug: c.slug }))}
      />
    </div>

    {relatedArticles.length > 0 && (
      <>
        <hr class="ArticlePage__separator" aria-hidden="true" />
        <section class="ArticlePage__related" aria-label="Más noticias de la sección">
          <NewsList
            articles={relatedArticles}
            showHeader={false}
            itemMinHeight="9rem"
            expandedPreview={true}
          />
        </section>
      </>
    )}

    <div class="ArticlePage__nav">
      <CategoryNav />
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .ArticlePage {
    background: var(--color-brand-dark);
    padding-top: 1.5rem;
    padding-bottom: 1rem;
  }

  .ArticlePage__container {
    padding: 0 clamp(1rem, 4vw, 3rem);
  }

  /* Separador blanco fino entre el artículo y la lista de relacionados. */
  .ArticlePage__separator {
    border: 0;
    height: 4px;
    background: var(--color-brand-white);
    margin: 3rem 0 0;
    width: 100%;
  }

  /* Lista de relacionados: ocupa casi todo el ancho del viewport,
     alineada con el mismo padding lateral que el CategoryNav (1rem). */
  .ArticlePage__related {
    margin-top: 0;
    padding: 0 1rem;
  }

  /* En la página de artículo el CategoryNav se distribuye con
     space-between para ocupar todo el ancho con botones más grandes.    */
  .ArticlePage__nav :global(.CategoryNav) {
    gap: 0.5rem;
    padding: 3rem 1rem 2rem;
  }

  .ArticlePage__nav :global(.CategoryNav .PillButton--category) {
    font-size: 1.95rem;
    padding: 0.1rem 1rem;
  }

  @media (max-width: 900px) {
    .ArticlePage__nav :global(.CategoryNav) {
      justify-content: center;
    }
    .ArticlePage__nav :global(.CategoryNav .PillButton--category) {
      font-size: 1.5rem;
    }
  }

  @media (max-width: 640px) {
    .ArticlePage {
      padding-top: 1rem;
    }

    .ArticlePage__separator {
      margin-top: 2rem;
    }
  }
</style>
