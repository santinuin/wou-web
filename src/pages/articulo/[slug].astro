---
/**
 * Página de artículo — on-demand (Cloudflare Worker).
 *
 * Fetch: Sanity GROQ → fetchSanityPostBySlug(slug)
 * Cache: s-maxage=2592000 (30 días) en el edge de Cloudflare.
 * Invalidación: webhook de Sanity → Cloudflare Pages Deploy Hook.
 */
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import ArticleCard from '@/sections/article/ArticleCard.astro';
import NewsList from '@/components/content/NewsList.astro';
import CategoryNav from '@/sections/category/CategoryNav.astro';
import { fetchSanityPostBySlug, fetchSanityPostsByCategory } from '@/lib/cms';

const { slug } = Astro.params;

if (!slug) return Astro.redirect('/404');

const post = await fetchSanityPostBySlug(slug);

if (!post) return Astro.redirect('/404');

// Cache en Cloudflare Edge: 30 días.
// El webhook de Sanity dispara un nuevo deploy para invalidar.
Astro.response.headers.set(
  'Cache-Control',
  'public, no-store, s-maxage=2592000, stale-while-revalidate=86400'
);

const { data } = post;
const title = data.title;
const excerpt = data.excerpt ?? '';
const featuredImage = data.mainImage?.url ?? null;
const featuredImageAlt = data.mainImage?.alt ?? title;
const featuredImageWidth = data.mainImage?.width ?? 1200;
const featuredImageHeight = data.mainImage?.height ?? 675;
const categories = data.categories ?? [];
const primaryCategory = categories[0] ?? null;

// Artículos relacionados: hasta 4 de la misma categoría (excluye este artículo).
const relatedArticles = primaryCategory
  ? (await fetchSanityPostsByCategory(primaryCategory.slug.current, 0, 5))
      .filter((p) => p.data.slug.current !== slug)
      .slice(0, 4)
      .map((p) => ({
        title: p.data.title,
        publishedAt: p.data.publishedAt ?? '',
        slug: p.data.slug.current,
        href: `/articulo/${p.data.slug.current}`,
        imageUrl: p.data.mainImage?.url ?? null,
        excerpt: p.data.excerpt ?? null,
      }))
  : [];
---

<BaseLayout
  title={title}
  description={excerpt}
  ogImage={featuredImage ?? undefined}
  canonicalUrl={data.seo?.canonicalUrl ?? data.originalUrl ?? undefined}
>
  <Header slot="header" />

  <div class="ArticlePage">
    <div class="ArticlePage__container">
      <ArticleCard
        title={title}
        excerpt={excerpt}
        body={data.body}
        publishedAt={data.publishedAt ?? ''}
        featuredImage={featuredImage}
        featuredImageAlt={featuredImageAlt}
        featuredImageWidth={featuredImageWidth}
        featuredImageHeight={featuredImageHeight}
        categories={categories.map((c) => ({ name: c.title, slug: c.slug.current }))}
        needsReview={data.needsReview ?? false}
      />
    </div>

    {relatedArticles.length > 0 && (
      <>
        <hr class="ArticlePage__separator" aria-hidden="true" />
        <section class="ArticlePage__related" aria-label="Más noticias de la sección">
          <NewsList
            articles={relatedArticles}
            showHeader={false}
            itemMinHeight="9rem"
            expandedPreview={true}
          />
        </section>
      </>
    )}

    <div class="ArticlePage__nav">
      <CategoryNav />
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .ArticlePage {
    background: var(--color-brand-dark);
    padding-top: 1.5rem;
    padding-bottom: 1rem;
  }

  .ArticlePage__container {
    padding: 0 clamp(1rem, 4vw, 3rem);
  }

  .ArticlePage__separator {
    border: 0;
    height: 4px;
    background: var(--color-brand-white);
    margin: 3rem 0 0;
    width: 100%;
  }

  .ArticlePage__related {
    margin-top: 0;
    padding: 0 1rem;
  }

  .ArticlePage__nav :global(.CategoryNav) {
    gap: 0.5rem;
    padding: 3rem 1rem 2rem;
  }

  .ArticlePage__nav :global(.CategoryNav .PillButton--category) {
    font-size: 1.95rem;
    padding: 0.1rem 1rem;
  }

  @media (max-width: 900px) {
    .ArticlePage__nav :global(.CategoryNav) {
      justify-content: center;
    }
    .ArticlePage__nav :global(.CategoryNav .PillButton--category) {
      font-size: 1.5rem;
    }
  }

  @media (max-width: 640px) {
    .ArticlePage {
      padding-top: 1rem;
    }
    .ArticlePage__separator {
      margin-top: 2rem;
    }
  }
</style>
