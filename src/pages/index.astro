---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from '@/sections/home/Hero.astro';
import RedCircle from '@/sections/home/RedCircle.astro';
import TransitionSection from '@/sections/home/TransitionSection.astro';
import TextSeparator from '@/sections/home/TextSeparator.astro';
import Lineup from '@/sections/home/Lineup.astro';
import Videos from '@/sections/home/Videos.astro';
import NewsGrid from '@/sections/home/NewsGrid.astro';
---

<BaseLayout title="Portada">
  <Header slot="header" />
  <Hero />
  <RedCircle />
  <TransitionSection />
  <NewsGrid />
  <TextSeparator />
  <Lineup />
  <Videos />
  <Footer slot="footer" />
</BaseLayout>
