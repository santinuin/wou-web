---
/**
 * Página de categoría — prerendizado en build-time.
 *
 * Fetch inicial: Sanity → fetchSanityPostsByCategory (16 artículos por categoría).
 * LoadMore: fetch al endpoint /api/category-posts (Cloudflare Worker) desde el browser.
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import CategoryHero from '@/sections/category/CategoryHero.astro';
import CategoryGrid from '@/sections/category/CategoryGrid.astro';
import CategoryNav from '@/sections/category/CategoryNav.astro';
import LoadMore from '@/components/ui/LoadMore.svelte';
import { BAND_PATTERN } from '@/sections/category/bandPattern';
import { fetchSanityPostsByCategory } from '@/lib/cms';
import type { ArticleLike } from '@/sections/home/mocks/newsGridMock';

export const prerender = true;

// Categorías del portal — slug para la ruta y para la query de Sanity.
const CATEGORIES = [
  { slug: 'circulo-rojo',  display: 'Círculo Rojo' },
  { slug: 'politica',      display: 'Política'     },
  { slug: 'locales',       display: 'Locales'      },
  { slug: 'policiales',    display: 'Policiales'   },
  { slug: 'opinion',       display: 'Opinión'      },
  { slug: 'deportes',      display: 'Deportes'     },
  { slug: 'sociedad',      display: 'Sociedad'     },
  { slug: 'cultura',       display: 'Cultura'      },
  { slug: 'economia',      display: 'Economía'     },
  { slug: 'turismo',       display: 'Turismo'      },
  { slug: 'ambiente',      display: 'Ambiente'     },
  { slug: 'nacionales',    display: 'Nacionales'   },
] as const;

export async function getStaticPaths() {
  const paths = await Promise.all(
    CATEGORIES.map(async ({ slug, display }) => {
      const posts = await fetchSanityPostsByCategory(slug, 0, 16);

      // Normalizar al shape ArticleLike que consumen CategoryHero y CategoryGrid.
      // Cast necesario: ArticleLike es un tipo mínimo que no incluye
      // todos los campos del shape de Sanity (modifiedAt, tags, etc.).
      const articles: ArticleLike[] = posts.map((p) => ({
        id: p.id,
        data: {
          wpId: p.data.wpId ?? undefined,
          title: p.data.title,
          slug: p.data.slug,
          publishedAt: p.data.publishedAt ?? null,
          excerpt: p.data.excerpt ?? null,
          mainImage: p.data.mainImage ?? null,
          categories: p.data.categories ?? [],
          featured: p.data.featured ?? null,
          highlightWord: p.data.highlightWord ?? null,
        },
      })) as ArticleLike[];

      return {
        params: { categoria: slug },
        props: { display, categorySlug: slug, articles },
      };
    })
  );

  return paths;
}

interface Props {
  display: string;
  categorySlug: string;
  articles: ArticleLike[];
}

const { display, categorySlug, articles } = Astro.props;

const heroArticle = articles[0] ?? null;
const gridArticles = articles.slice(1);

// Calcular el offset de patrón inicial para que LoadMore continúe
// el ritmo de banda donde lo dejó el grid SSG.
let initialPatternOffset = 0;
let cursor = 0;
while (cursor < gridArticles.length) {
  const cols = BAND_PATTERN[initialPatternOffset % BAND_PATTERN.length].cols;
  cursor += cols;
  initialPatternOffset++;
}

// LoadMore arranca desde donde termina el SSG
const initialOffset = articles.length;
---

<BaseLayout title={display}>
  <Header slot="header" />

  <div class="CategoryPage">
    <span class="CategoryPage__watermark CategoryPage__watermark--left" aria-hidden="true">
      {display}
    </span>
    <span class="CategoryPage__watermark CategoryPage__watermark--right" aria-hidden="true">
      {display}
    </span>

    <div class="CategoryPage__container">
      {heroArticle && (
        <CategoryHero article={heroArticle} categoryDisplay={display} />
      )}

      {gridArticles.length > 0 && (
        <CategoryGrid articles={gridArticles} />
      )}

      {articles.length > 0 && (
        <LoadMore
          categorySlug={categorySlug}
          initialOffset={initialOffset}
          initialPatternOffset={initialPatternOffset}
          client:visible
        />
      )}

      {articles.length === 0 && (
        <div class="CategoryPage__empty">
          <p>No hay artículos disponibles en esta sección.</p>
        </div>
      )}

      <CategoryNav />
    </div>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .CategoryPage {
    position: relative;
    background: var(--color-brand-dark);
    overflow: hidden;
  }

  .CategoryPage__container {
    padding: 1.5rem 13.5rem;
    display: flex;
    flex-direction: column;
    gap: 8px;
    position: relative;
    z-index: 1;
  }

  .CategoryPage__watermark {
    position: absolute;
    top: 0;
    font-family: var(--font-alumni);
    font-weight: 700;
    font-size: clamp(6rem, 13vw, 15rem);
    text-transform: uppercase;
    color: var(--color-brand-blue);
    opacity: 0.35;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    line-height: 0.59;
    pointer-events: none;
    user-select: none;
    z-index: 0;
    letter-spacing: -0.02em;
    transform: rotate(180deg);
  }

  .CategoryPage__watermark--left { left: 0; }
  .CategoryPage__watermark--right { right: 0; }

  .CategoryPage__empty {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 40vh;
    color: var(--color-brand-white);
    font-family: var(--font-alumni);
    font-size: 2rem;
    opacity: 0.5;
  }

  @media (max-width: 1280px) {
    .CategoryPage__container { padding: 1.5rem 6rem; }
  }
  @media (max-width: 1024px) {
    .CategoryPage__container { padding: 1.25rem 3rem; }
    .CategoryPage__watermark { font-size: 7rem; }
  }
  @media (max-width: 640px) {
    .CategoryPage__container { padding: 0.75rem 1rem; }
    .CategoryPage__watermark { display: none; }
  }
</style>
