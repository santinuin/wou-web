---
import PillButton from './PillButton.astro';

interface Props {
  href?: string;
  label?: string;
}

const { href = '/secciones', label = '+ SECCIONES' } = Astro.props;
---

<div class="flex justify-center items-center py-40 pb-0 bg-brand-dark">
  <PillButton href={href} label={label} variant="primary" ariaLabel="Ver todas las secciones" />
</div>
