---
import ReelsCarousel from '@/components/ui/ReelsCarousel.svelte';
import { getLatestYoutubeShorts } from '@/lib/youtube';

const items = await getLatestYoutubeShorts(8);
---

{items.length > 0 && (
  <section class="ReelsBand" aria-label="Últimos reels">
    <h2 class="ReelsBand__title">Últimos videos</h2>
    <ReelsCarousel client:only="svelte" {items} />
  </section>
)}

<style>
  .ReelsBand {
    background: var(--color-brand-gray);
    padding: 2rem 0 2.5rem;
  }

  .ReelsBand__title {
    font-family: var(--font-boldonse), sans-serif;
    font-weight: 400;
    font-size: clamp(1.4rem, 3.2vw, 2.6rem);
    color: var(--color-brand-red);
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1;
    margin: 0 0 1.25rem;
  }
</style>
