---
import { getImageUrl } from '@/lib/cms';
import HeroCard from './HeroCard.astro';
import SupportCard from './SupportCard.astro';
import WideSupportCard from './WideSupportCard.astro';
import type { ArticleLike } from '@/sections/home/mocks/newsGridMock';

interface Props {
  variant: 'hero-left' | 'hero-right';
  hero: ArticleLike;
  support: ArticleLike[];
}

const { variant, hero, support } = Astro.props;

function imgUrl(image: unknown, width: number): string | null {
  if (!image) return null;
  try {
    return getImageUrl(image as Parameters<typeof getImageUrl>[0], { width });
  } catch {
    return null;
  }
}

// En hero-right la wide card es s3 → ponerle el más reciente (support[0])
const ordered = variant === 'hero-right'
  ? [support[1], support[2], support[0]]
  : support;

const heroImgUrl  = imgUrl(hero.data.mainImage, 640);
const s1ImgUrl    = imgUrl(ordered[0]?.data.mainImage, variant === 'hero-left' ? 560 : 360);
const s2ImgUrl    = imgUrl(ordered[1]?.data.mainImage, 360);
const s3ImgUrl    = imgUrl(ordered[2]?.data.mainImage, variant === 'hero-right' ? 560 : 360);

const heroCategory = hero.data.categories?.[0]?.title ?? null;
---

<section class:list={['NewsBand', `NewsBand--${variant}`]}>
  <!-- Hero: DOM-first para accesibilidad; CSS lo posiciona visualmente -->
  <div class="NewsBand__hero">
    <HeroCard
      title={hero.data.title}
      slug={hero.data.slug.current}
      categoryTitle={heroCategory}
      imageUrl={heroImgUrl}
      imageAlt={hero.data.mainImage?.alt ?? hero.data.title}
      tickerText={hero.data.excerpt ?? null}
      highlightWord={hero.data.highlightWord ?? null}
    />
  </div>

  {ordered[0] && (
    <div class="NewsBand__s1">
      {variant === 'hero-left'
        ? <WideSupportCard
            title={ordered[0].data.title}
            slug={ordered[0].data.slug.current}
            categoryTitle={ordered[0].data.categories?.[0]?.title ?? null}
            imageUrl={s1ImgUrl}
            imageAlt={ordered[0].data.mainImage?.alt ?? ordered[0].data.title}
          />
        : <SupportCard
            title={ordered[0].data.title}
            slug={ordered[0].data.slug.current}
            categoryTitle={ordered[0].data.categories?.[0]?.title ?? null}
            imageUrl={s1ImgUrl}
            imageAlt={ordered[0].data.mainImage?.alt ?? ordered[0].data.title}
          />
      }
    </div>
  )}

  {ordered[1] && (
    <div class="NewsBand__s2">
      <SupportCard
        title={ordered[1].data.title}
        slug={ordered[1].data.slug.current}
        categoryTitle={ordered[1].data.categories?.[0]?.title ?? null}
        imageUrl={s2ImgUrl}
        imageAlt={ordered[1].data.mainImage?.alt ?? ordered[1].data.title}
      />
    </div>
  )}

  {ordered[2] && (
    <div class="NewsBand__s3">
      {variant === 'hero-right'
        ? <WideSupportCard
            title={ordered[2].data.title}
            slug={ordered[2].data.slug.current}
            categoryTitle={ordered[2].data.categories?.[0]?.title ?? null}
            imageUrl={s3ImgUrl}
            imageAlt={ordered[2].data.mainImage?.alt ?? ordered[2].data.title}
          />
        : <SupportCard
            title={ordered[2].data.title}
            slug={ordered[2].data.slug.current}
            categoryTitle={ordered[2].data.categories?.[0]?.title ?? null}
            imageUrl={s3ImgUrl}
            imageAlt={ordered[2].data.mainImage?.alt ?? ordered[2].data.title}
          />
      }
    </div>
  )}
</section>

<style>
  .NewsBand {
    display: grid;
    grid-template-rows: minmax(220px, 1fr) minmax(220px, 1fr);
    gap: 8px;
    background: var(--color-brand-dark);
    border-radius: 10px;
    overflow: hidden;
    max-height: 85vh;
  }

  /* Cada celda es flex column para que el hijo ocupe el 100% de altura */
  .NewsBand__hero,
  .NewsBand__s1,
  .NewsBand__s2,
  .NewsBand__s3 {
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* ── Hero-left: [2fr 1fr 1fr] ──────────────────────────────────── */
  .NewsBand--hero-left {
    grid-template-columns: 2fr 1fr 1fr;
  }

  .NewsBand--hero-left .NewsBand__hero { grid-column: 1; grid-row: 1 / span 2; }
  .NewsBand--hero-left .NewsBand__s1   { grid-column: 2 / span 2; grid-row: 1; }
  .NewsBand--hero-left .NewsBand__s2   { grid-column: 2; grid-row: 2; }
  .NewsBand--hero-left .NewsBand__s3   { grid-column: 3; grid-row: 2; }

  /* ── Hero-right: [1fr 1fr 2fr] ─────────────────────────────────── */
  .NewsBand--hero-right {
    grid-template-columns: 1fr 1fr 2fr;
  }

  .NewsBand--hero-right .NewsBand__hero { grid-column: 3; grid-row: 1 / span 2; }
  .NewsBand--hero-right .NewsBand__s1   { grid-column: 1; grid-row: 1; }
  .NewsBand--hero-right .NewsBand__s2   { grid-column: 2; grid-row: 1; }
  .NewsBand--hero-right .NewsBand__s3   { grid-column: 1 / span 2; grid-row: 2; }

  /* ── Mobile: stack vertical ─────────────────────────────────────── */
  @media (max-width: 640px) {
    .NewsBand,
    .NewsBand--hero-left,
    .NewsBand--hero-right {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      min-height: unset;
    }

    .NewsBand--hero-left .NewsBand__hero,
    .NewsBand--hero-right .NewsBand__hero,
    .NewsBand--hero-left .NewsBand__s1,
    .NewsBand--hero-right .NewsBand__s1,
    .NewsBand--hero-left .NewsBand__s2,
    .NewsBand--hero-right .NewsBand__s2,
    .NewsBand--hero-left .NewsBand__s3,
    .NewsBand--hero-right .NewsBand__s3 {
      grid-column: 1;
      grid-row: auto;
    }

    .NewsBand__hero { min-height: 280px; }
  }
</style>
