---
import { getImageUrl } from '@/lib/cms';
import AdCard from './AdCard.astro';
import type { AdLike } from '@/sections/home/mocks/newsGridMock';

interface Props {
  ads: AdLike[];
}

const { ads } = Astro.props;

const [ad1, ad2, ad3] = ads;

function imgUrl(ad: AdLike | undefined, width: number): string | null {
  if (!ad?.data.image) return null;
  try {
    return getImageUrl(ad.data.image as Parameters<typeof getImageUrl>[0], { width });
  } catch {
    return null;
  }
}
---

{(ad1 || ad2 || ad3) && (
  <section class="AdsBand1" aria-label="Espacios publicitarios">
    {ad1 && (
      <div class="AdsBand1__item AdsBand1__item--wide">
        <AdCard
          title={ad1.data.title}
          imageUrl={imgUrl(ad1, 680)}
          imageAlt={ad1.data.image?.alt ?? ad1.data.brand ?? ad1.data.title}
          url={ad1.data.url ?? null}
        />
      </div>
    )}
    {ad2 && (
      <div class="AdsBand1__item">
        <AdCard
          title={ad2.data.title}
          imageUrl={imgUrl(ad2, 340)}
          imageAlt={ad2.data.image?.alt ?? ad2.data.brand ?? ad2.data.title}
          url={ad2.data.url ?? null}
        />
      </div>
    )}
    {ad3 && (
      <div class="AdsBand1__item">
        <AdCard
          title={ad3.data.title}
          imageUrl={imgUrl(ad3, 340)}
          imageAlt={ad3.data.image?.alt ?? ad3.data.brand ?? ad3.data.title}
          url={ad3.data.url ?? null}
        />
      </div>
    )}
  </section>
)}

<style>
  .AdsBand1 {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 6px;
    height: 230px;
    border-radius: 10px;
    overflow: hidden;
  }

  .AdsBand1__item {
    border-radius: 8px;
    overflow: hidden;
    height: 100%;
  }

  /* ── Tablet ── */
  @media (max-width: 1024px) and (min-width: 641px) {
    .AdsBand1 { height: 130px; }
  }

  /* ── Mobile: columna única, altura más corta ── */
  @media (max-width: 640px) {
    .AdsBand1 {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      height: auto;
    }

    .AdsBand1__item--wide {
      grid-column: 1 / span 2;
      height: 120px;
    }

    .AdsBand1__item:not(.AdsBand1__item--wide) {
      height: 100px;
    }
  }
</style>
