---
import { Image } from 'astro:assets';
import { timeAgo, formatDateDots } from '@/lib/utils';

interface NewsItem {
  title: string;
  publishedAt: string;
  slug: string;
  href?: string;
  imageUrl?: string | null;
  excerpt?: string | null;
}

interface Props {
  articles: NewsItem[];
  buildDate?: Date;
  showHeader?: boolean;
  itemMinHeight?: string;
  /**
   * Modo expandido: ítems más altos, preview (imagen + bajada) ocupa todo
   * el ancho disponible al hacer hover y empuja al título. Usado en la
   * página de artículo donde el listado tiene mucho espacio horizontal.
   */
  expandedPreview?: boolean;
}

const {
  articles,
  buildDate = new Date(),
  showHeader = true,
  itemMinHeight,
  expandedPreview = false,
} = Astro.props;

// Clases dependientes del modo expandido. Se calculan acá para que el
// markup no se vuelva ilegible y para que Tailwind v4 detecte las clases
// completas durante el scan estático.
const previewWrapClasses = expandedPreview
  ? 'group-hover:max-w-[30%] group-[.is-pressed]:max-w-[60%]'
  : 'group-hover:max-w-70 group-[.is-pressed]:max-w-[55%]';
const previewImageClasses = expandedPreview
  ? 'w-14 h-14 lg:w-20 lg:h-20'
  : 'w-12 h-12 lg:w-14 lg:h-14';
// En modo expandido la descripción usa ancho FIJO (no flex-1) para que
// el texto no re-fluya durante la animación de hover. El wrap clipea
// con overflow:hidden hasta llegar al final del barrido.
const previewExcerptClasses = expandedPreview
  ? 'w-[12rem] lg:w-[20rem] shrink-0 font-bold'
  : 'w-32 lg:w-40 shrink-0';
const titleClasses = expandedPreview
  ? 'text-lg sm:text-xl md:text-2xl lg:text-4xl'
  : 'text-sm sm:text-base md:text-lg lg:text-2xl';
const timeClasses = expandedPreview
  ? 'text-[10px] sm:text-xs lg:text-sm'
  : 'text-[10px] sm:text-xs';
---

<div class="NL flex flex-col bg-brand-dark h-full">

  {showHeader && (
    <!-- Encabezado -->
    <div class="NL__header px-4 pt-4 lg:px-5 lg:pt-10 border-b-2 lg:border-b-10 border-brand-teal" style="container-type: inline-size;">
      <div class="flex items-end gap-2 lg:gap-3 leading-none pb-0">
        <span
          class="NL__title font-boldonse text-brand-teal leading-none whitespace-nowrap pl-0 lg:pl-4"
          style="font-size: clamp(1.125rem, 4.5vw, 3.4rem);"
        >
          PONETE AL DÍA
        </span>
        <span
          class="NL__date font-franklin font-bold text-brand-teal leading-none whitespace-nowrap shrink-0 -mb-0.5 lg:-mb-1.75"
          style="font-size: clamp(0.75rem, 1.8vw, 1.5rem);"
        >
          {formatDateDots(buildDate)}
        </span>
      </div>
    </div>
  )}

  <!--
    Lista de noticias.
    Cada <li> es un `group` para activar el hover compartido de:
      · Sweep del fondo (scaleY de arriba hacia abajo)
      · Reveal del preview (imagen + excerpt) con transición de max-width
      · Desplazamiento del título a la derecha (empujado por el preview)
  -->
  <ul class="flex-1 flex flex-col">
    {articles.map((article) => (
      <li
        class="group relative flex flex-1"
        style={itemMinHeight ? `min-height: ${itemMinHeight}` : undefined}
      >
        <a
          href={article.href ?? `/articulo/${article.slug}`}
          class="relative flex flex-1 items-center px-4 lg:px-5 overflow-hidden"
        >
          {/*
            Sweep background — barrido vertical del color de hover.
          */}
          <span
            aria-hidden="true"
            class="absolute inset-0 bg-brand-blue origin-top scale-y-0 transition-transform duration-500 ease-[cubic-bezier(0.65,0,0.35,1)] group-hover:scale-y-100 group-[.is-pressed]:scale-y-100"
          ></span>

          {/*
            Panel de preview (imagen + excerpt).
            Colapsado en reposo (max-w-0, opacity-0); se expande a la derecha
            empujando al título al entrar en hover (desktop) o long-press (touch).
          */}
          {(article.imageUrl || article.excerpt) && (
            <span class:list={[
              'relative flex items-center gap-3 lg:gap-4 max-w-0 opacity-0 overflow-hidden transition-all duration-500 ease-out group-hover:opacity-100 group-hover:mr-6 group-[.is-pressed]:opacity-100 group-[.is-pressed]:mr-4',
              previewWrapClasses,
            ]}>
              {article.imageUrl && (
                <Image
                  src={article.imageUrl}
                  alt={article.title}
                  width={160}
                  height={160}
                  class:list={[
                    previewImageClasses,
                    'object-cover rounded shrink-0',
                  ]}
                  loading="lazy"
                />
              )}
              {article.excerpt && (
                <span class:list={[
                  'font-franklin text-brand-white text-sm leading-snug line-clamp-3',
                  previewExcerptClasses,
                ]}>
                  {article.excerpt}
                </span>
              )}
            </span>
          )}

          <span class:list={[
            'relative flex-1 min-w-0 font-franklin font-bold text-brand-white uppercase tracking-wide truncate transition-colors',
            titleClasses,
          ]}>
            {article.title}
          </span>

          <span class:list={[
            'relative ml-auto font-sans text-brand-white/40 shrink-0 pl-4 group-hover:text-brand-white/70 transition-colors',
            timeClasses,
          ]}>
            {timeAgo(article.publishedAt)}
          </span>
        </a>
      </li>
    ))}
  </ul>
</div>

<script>
  // Anula toda transición CSS mientras el scroll va de abajo hacia arriba.
  // Comportamiento como página normal — sin sweep, sin reveal, sin fades.
  const roots = document.querySelectorAll<HTMLElement>('.NL');
  if (roots.length) {
    let lastY = window.scrollY;
    let timer: ReturnType<typeof setTimeout> | null = null;
    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      if (y < lastY) {
        roots.forEach((r) => r.classList.add('is-scrolling-up'));
      }
      lastY = y;
      if (timer) clearTimeout(timer);
      timer = setTimeout(() => {
        roots.forEach((r) => r.classList.remove('is-scrolling-up'));
      }, 150);
    }, { passive: true });
  }

  /* Long-press preview en touch
     ───────────────────────────
     En mobile/tablet :hover no aplica naturalmente. Detectamos un press
     sostenido (>350ms sin scroll) y aplicamos `.is-pressed` al <li.group>
     para disparar el mismo efecto visual del hover desktop.
     · Si el usuario movió el dedo >10px → era un scroll, cancelamos.
     · Si fue un long-press → suprimimos el click siguiente (release no navega).
     · El preview queda visible ~1s para que el usuario lo lea, luego se cierra.
     · Un tap normal (corto) navega como siempre. */
  const items = document.querySelectorAll<HTMLLIElement>('.NL li.group');
  const LONG_PRESS_MS = 350;
  const MOVE_TOLERANCE_PX = 10;
  const PREVIEW_LINGER_MS = 1100;

  items.forEach((item) => {
    let timer: ReturnType<typeof setTimeout> | null = null;
    let lingerTimer: ReturnType<typeof setTimeout> | null = null;
    let pressed = false;
    let suppressClick = false;
    let startX = 0;
    let startY = 0;

    const clearTimer = () => {
      if (timer) { clearTimeout(timer); timer = null; }
    };

    const closePreview = () => {
      item.classList.remove('is-pressed');
      pressed = false;
    };

    item.addEventListener('pointerdown', (e) => {
      if (e.pointerType !== 'touch') return;
      // Si había un preview abierto de un press anterior, ciérralo
      if (lingerTimer) { clearTimeout(lingerTimer); lingerTimer = null; }
      closePreview();
      startX = e.clientX;
      startY = e.clientY;
      clearTimer();
      timer = setTimeout(() => {
        pressed = true;
        suppressClick = true;
        item.classList.add('is-pressed');
        timer = null;
      }, LONG_PRESS_MS);
    });

    item.addEventListener('pointermove', (e) => {
      if (e.pointerType !== 'touch') return;
      const dx = Math.abs(e.clientX - startX);
      const dy = Math.abs(e.clientY - startY);
      if (dx > MOVE_TOLERANCE_PX || dy > MOVE_TOLERANCE_PX) {
        clearTimer();
        if (pressed) closePreview();
      }
    });

    const finish = (e: PointerEvent) => {
      if (e.pointerType !== 'touch') return;
      clearTimer();
      if (pressed) {
        // Mantenemos el preview visible un toque después del release
        if (lingerTimer) clearTimeout(lingerTimer);
        lingerTimer = setTimeout(() => {
          closePreview();
          lingerTimer = null;
        }, PREVIEW_LINGER_MS);
      }
    };

    item.addEventListener('pointerup', finish);
    item.addEventListener('pointercancel', finish);

    // El click llega después del pointerup en touch — si fue long-press,
    // bloqueamos la navegación de ese tap (el usuario solo previsualizó).
    item.addEventListener('click', (e) => {
      if (suppressClick) {
        e.preventDefault();
        e.stopPropagation();
        suppressClick = false;
      }
    }, true);
  });
</script>

<style>
  .NL.is-scrolling-up *,
  .NL.is-scrolling-up *::before,
  .NL.is-scrolling-up *::after {
    transition: none !important;
    animation: none !important;
  }

  /* En touch :hover queda "pegado" hasta tocar otra cosa.
     Desactivamos hover en dispositivos sin puntero fino — el long-press
     vía .is-pressed cubre la interacción. */
  @media (hover: none) {
    .NL .group:hover .group-hover\:opacity-100 { opacity: 0; }
    .NL .group:hover [class*="group-hover:max-w"] { max-width: 0; }
    .NL .group:hover .group-hover\:scale-y-100 { transform: scaleY(0); }
    .NL .group:hover .group-hover\:mr-6 { margin-right: 0; }
  }
</style>

