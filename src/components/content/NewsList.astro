---
import { Image } from 'astro:assets';
import { timeAgo, formatDateDots } from '@/lib/utils';

interface NewsItem {
  title: string;
  publishedAt: string;
  slug: string;
  imageUrl?: string | null;
  excerpt?: string | null;
}

interface Props {
  articles: NewsItem[];
  buildDate?: Date;
}

const { articles, buildDate = new Date() } = Astro.props;
---

<div class="flex flex-col bg-brand-black h-full">

  <!-- Encabezado -->
  <div class="NL__header px-5 pt-10 border-b-10 border-brand-teal">
    <div class="flex items-baseline gap-3 leading-none">
      <span class="NL__title font-boldonse text-brand-teal leading-none whitespace-nowrap" style="font-size: 3rem;">
        PONETE AL DÍA
      </span>
      <span class="NL__date font-boldonse text-brand-teal leading-none whitespace-nowrap shrink-0" style="font-size: 1.1rem;">
        {formatDateDots(buildDate)}
      </span>
    </div>
  </div>

  <!--
    Lista de noticias.
    Cada <li> es un `group` para activar el hover compartido de:
      · Sweep del fondo (scaleY de arriba hacia abajo)
      · Reveal del preview (imagen + excerpt) con transición de max-width
      · Desplazamiento del título a la derecha (empujado por el preview)
  -->
  <ul class="flex-1 flex flex-col">
    {articles.map((article) => (
      <li class="group relative flex-1">
        <a
          href={`/articulo/${article.slug}`}
          class="relative flex items-center px-5 h-full overflow-hidden"
        >
          {/*
            Sweep background — barrido vertical del color de hover.
          */}
          <span
            aria-hidden="true"
            class="absolute inset-0 bg-brand-blue origin-top scale-y-0 transition-transform duration-500 ease-[cubic-bezier(0.65,0,0.35,1)] group-hover:scale-y-100"
          ></span>

          {/*
            Panel de preview (imagen + excerpt).
            Colapsado en reposo (max-w-0, opacity-0); se expande a la derecha
            empujando al título al entrar en hover.
          */}
          {(article.imageUrl || article.excerpt) && (
            <span class="relative flex items-center gap-4 max-w-0 opacity-0 overflow-hidden transition-all duration-500 ease-out group-hover:max-w-70 group-hover:opacity-100 group-hover:mr-6">
              {article.imageUrl && (
                <Image
                  src={article.imageUrl}
                  alt={article.title}
                  width={200}
                  height={140}
                  class="w-25 h-75.5 object-cover shrink-0"
                  loading="lazy"
                />
              )}
              {article.excerpt && (
                <span class="font-franklin text-brand-white text-sm leading-snug shrink-0 w-40">
                  {article.excerpt}
                </span>
              )}
            </span>
          )}

          <span class="relative font-franklin font-bold text-brand-white text-2xl uppercase tracking-wide whitespace-nowrap transition-colors">
            {article.title}
          </span>

          <span class="relative ml-auto font-sans text-brand-white/40 text-xs shrink-0 pl-4 group-hover:text-brand-white/70 transition-colors">
            {timeAgo(article.publishedAt)}
          </span>
        </a>
      </li>
    ))}
  </ul>
</div>

<script>
  const header = document.querySelector<HTMLElement>('.NL__header');
  const title  = document.querySelector<HTMLElement>('.NL__title');
  const date   = document.querySelector<HTMLElement>('.NL__date');

  function fitTitle() {
    if (!header || !title || !date) return;
    const available = header.clientWidth
      - parseInt(getComputedStyle(header).paddingLeft)
      - parseInt(getComputedStyle(header).paddingRight)
      - date.offsetWidth
      - 12; // gap

    let lo = 16, hi = 75;
    while (hi - lo > 0.5) {
      const mid = (lo + hi) / 2;
      title.style.fontSize = `${mid}px`;
      title.scrollWidth <= available ? (lo = mid) : (hi = mid);
    }
    title.style.fontSize = `${Math.floor(lo)}px`;

    // fecha proporcional: ~32% del título
    date.style.fontSize = `${Math.floor(lo * 0.32)}px`;
  }

  document.fonts.ready.then(fitTitle);
  if (header) new ResizeObserver(fitTitle).observe(header);
</script>
