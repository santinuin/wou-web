---
import { Image } from 'astro:assets';
import { timeAgo, formatDateDots } from '@/lib/utils';

interface NewsItem {
  title: string;
  publishedAt: string;
  slug: string;
  href?: string;
  imageUrl?: string | null;
  excerpt?: string | null;
}

interface Props {
  articles: NewsItem[];
  buildDate?: Date;
}

const { articles, buildDate = new Date() } = Astro.props;
---

<div class="NL flex flex-col bg-brand-dark h-full">

  <!-- Encabezado -->
  <div class="NL__header px-5 pt-10 border-b-10 border-brand-teal" style="container-type: inline-size;">
    <div class="flex items-end gap-3 leading-none pb-0">
      <span class="NL__title font-boldonse text-brand-teal leading-none whitespace-nowrap pl-4" style="font-size: 8.5cqw;">
        PONETE AL DÍA
      </span>
      <span class="NL__date font-franklin font-bold text-brand-teal leading-none whitespace-nowrap shrink-0 -mb-1.75" style="font-size: 4cqw;">
        {formatDateDots(buildDate)}
      </span>
    </div>
  </div>

  <!--
    Lista de noticias.
    Cada <li> es un `group` para activar el hover compartido de:
      · Sweep del fondo (scaleY de arriba hacia abajo)
      · Reveal del preview (imagen + excerpt) con transición de max-width
      · Desplazamiento del título a la derecha (empujado por el preview)
  -->
  <ul class="flex-1 flex flex-col">
    {articles.map((article) => (
      <li class="group relative flex-1">
        <a
          href={article.href ?? `/articulo/${article.slug}`}
          class="relative flex items-center px-5 h-full overflow-hidden"
        >
          {/*
            Sweep background — barrido vertical del color de hover.
          */}
          <span
            aria-hidden="true"
            class="absolute inset-0 bg-brand-blue origin-top scale-y-0 transition-transform duration-500 ease-[cubic-bezier(0.65,0,0.35,1)] group-hover:scale-y-100"
          ></span>

          {/*
            Panel de preview (imagen + excerpt).
            Colapsado en reposo (max-w-0, opacity-0); se expande a la derecha
            empujando al título al entrar en hover.
          */}
          {(article.imageUrl || article.excerpt) && (
            <span class="relative flex items-center gap-4 max-w-0 opacity-0 overflow-hidden transition-all duration-500 ease-out group-hover:max-w-70 group-hover:opacity-100 group-hover:mr-6">
              {article.imageUrl && (
                <Image
                  src={article.imageUrl}
                  alt={article.title}
                  width={112}
                  height={112}
                  class="w-14 h-14 object-cover rounded shrink-0"
                  loading="lazy"
                />
              )}
              {article.excerpt && (
                <span class="font-franklin text-brand-white text-sm leading-snug shrink-0 w-40 line-clamp-3">
                  {article.excerpt}
                </span>
              )}
            </span>
          )}

          <span class="relative flex-1 min-w-0 font-franklin font-bold text-brand-white text-2xl uppercase tracking-wide truncate transition-colors">
            {article.title}
          </span>

          <span class="relative ml-auto font-sans text-brand-white/40 text-xs shrink-0 pl-4 group-hover:text-brand-white/70 transition-colors">
            {timeAgo(article.publishedAt)}
          </span>
        </a>
      </li>
    ))}
  </ul>
</div>

<script>
  // Anula toda transición CSS mientras el scroll va de abajo hacia arriba.
  // Comportamiento como página normal — sin sweep, sin reveal, sin fades.
  const roots = document.querySelectorAll<HTMLElement>('.NL');
  if (roots.length) {
    let lastY = window.scrollY;
    let timer: ReturnType<typeof setTimeout> | null = null;
    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      if (y < lastY) {
        roots.forEach((r) => r.classList.add('is-scrolling-up'));
      }
      lastY = y;
      if (timer) clearTimeout(timer);
      timer = setTimeout(() => {
        roots.forEach((r) => r.classList.remove('is-scrolling-up'));
      }, 150);
    }, { passive: true });
  }
</script>

<style>
  .NL.is-scrolling-up *,
  .NL.is-scrolling-up *::before,
  .NL.is-scrolling-up *::after {
    transition: none !important;
    animation: none !important;
  }
</style>

