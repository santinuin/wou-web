---
/**
 * Facade para el stream de YouTube.
 * Muestra un cover propio (95.1FM decorativo + play button) en lugar del
 * thumbnail de YouTube, para no romper el diseño.
 * Al hacer click carga el iframe con autoplay.
 */
import { getYoutubeStream } from '@/lib/youtube';
import { Image } from 'astro:assets';
import placeholderImg from '@/assets/youtube-placeholder.png';

interface Props {
  station?: string;
  handle?: string;
  filter?: string;
}

const { station = 'WOU! RADIO 95.1', filter } = Astro.props;

const { videoId, isLive } = await getYoutubeStream(filter);

const embedUrl = videoId
  ? `https://www.youtube.com/embed/${videoId}?autoplay=1`
  : null;
---

<div
  class="yt-facade relative w-full h-full bg-brand-black overflow-hidden group cursor-pointer"
  data-embed={embedUrl}
  role="button"
  tabindex="0"
  aria-label={`Reproducir ${station} en YouTube`}
>
  <!-- Fondo: imagen placeholder optimizada -->
  <Image
    src={placeholderImg}
    alt=""
    class="absolute inset-0 w-full h-full object-cover pointer-events-none select-none"
    loading="eager"
    aria-hidden="true"
  />

  <!-- Play button centrado -->
  <div class="absolute inset-0 flex items-center justify-center">
    <div class="w-14 h-10 bg-[#FF0000] rounded-lg flex items-center justify-center shadow-lg group-hover:scale-110 transition-transform">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M8 5v14l11-7z"/>
      </svg>
    </div>
  </div>

  <!-- Sin video disponible -->
  {!videoId && (
    <div class="absolute bottom-3 left-0 right-0 flex justify-center">
      <span class="font-barlow text-brand-white/30 text-xs tracking-widest uppercase">Sin stream</span>
    </div>
  )}
</div>

<script>
  document.querySelectorAll<HTMLElement>('.yt-facade').forEach((facade) => {
    const activate = () => {
      const src = facade.dataset.embed;
      if (!src) return;
      const iframe = document.createElement('iframe');
      iframe.src = src;
      iframe.allow = 'autoplay; encrypted-media; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.className = 'absolute inset-0 w-full h-full border-0';
      iframe.title = facade.getAttribute('aria-label') ?? 'YouTube';
      facade.innerHTML = '';
      facade.appendChild(iframe);
    };

    facade.addEventListener('click', activate);
    facade.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') activate();
    });
  });
</script>
