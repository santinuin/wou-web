---
import { Image } from 'astro:assets';
import { getPlaceholder } from '@/lib/placeholders';

interface Props {
  title: string;
  slug: string;
  categoryTitle?: string | null;
  imageUrl?: string | null;
  imageAlt?: string;
}

const { title, slug, categoryTitle, imageUrl, imageAlt = title } = Astro.props;
---

<a href={`/${slug}`} class="WideSupportCard" aria-label={title}>
  <div class="WideSupportCard__image-zone">
    {imageUrl
      ? <img src={imageUrl} alt={imageAlt} width="560" height="360" loading="lazy" decoding="async" class="WideSupportCard__image" />
      : <Image src={getPlaceholder(categoryTitle)} alt={imageAlt} width={560} height={360} loading="lazy" decoding="async" class="WideSupportCard__image" />
    }
  </div>

  <div class="WideSupportCard__body">
    {categoryTitle && (
      <span class="WideSupportCard__category">{categoryTitle}</span>
    )}
    <h3 class="WideSupportCard__title">{title}</h3>
  </div>
</a>

<style>
  .WideSupportCard {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: #ffffff;
    text-decoration: none;
    color: var(--color-brand-dark);
    overflow: visible;
    border: 2px solid var(--color-brand-dark);
    border-radius: 8px;
    transition: filter 0.2s ease;
  }

  .WideSupportCard:hover {
    filter: brightness(0.95);
  }

  .WideSupportCard__image-zone {
    flex: 0 0 60%;
    overflow: hidden;
    border-radius: 6px 6px 0 0;
  }

  .WideSupportCard__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .WideSupportCard:hover .WideSupportCard__image {
    transform: scale(1.03);
  }

  .WideSupportCard__body {
    flex: 0 0 40%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0.5rem 1.8rem 0.75rem;
    overflow: visible;
    position: relative;
  }

  .WideSupportCard__category {
    position: absolute;
    top: 0;
    left: 1.25rem;
    transform: translateY(-50%);
    display: inline-block;
    background: #ffffff;
    color: var(--color-brand-dark);
    font-family: var(--font-alumni);
    font-size: 1.7rem;
    font-weight: 700;
    padding: 0rem 0.7rem;
    border-radius: 9999px;
    line-height: 1.2;
    border: 2px solid var(--color-brand-black);
    white-space: nowrap;
    z-index: 1;
  }

  .WideSupportCard__title {
    font-family: var(--font-alumni);
    font-weight: 900;
    font-size: clamp(2.8rem, 5vw, 6.5rem);
    line-height: 0.9;
    margin: 0;
    color: var(--color-brand-dark);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
