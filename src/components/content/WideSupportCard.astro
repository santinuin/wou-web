---
import { Image } from 'astro:assets';
import { getPlaceholder } from '@/lib/placeholders';

interface Props {
  title: string;
  slug: string;
  categoryTitle?: string | null;
  imageUrl?: string | null;
  imageAlt?: string;
}

const { title, slug, categoryTitle, imageUrl, imageAlt = title } = Astro.props;
---

<a href={`/articulo/${slug}`} class="WideSupportCard" aria-label={title}>
  <div class="WideSupportCard__image-zone">
    {imageUrl
      ? <Image src={imageUrl} alt={imageAlt} width={560} height={360} loading="lazy" decoding="async" class="WideSupportCard__image" />
      : <Image src={getPlaceholder(categoryTitle)} alt={imageAlt} width={560} height={360} loading="lazy" decoding="async" class="WideSupportCard__image" />
    }
  </div>

  <div class="WideSupportCard__body">
    {categoryTitle && (
      <span class="WideSupportCard__category">{categoryTitle}</span>
    )}
    <h3 class="WideSupportCard__title" title={title}>{title}</h3>
  </div>
</a>

<style is:global>
  .WideSupportCard {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: #ffffff;
    text-decoration: none;
    color: var(--color-brand-white);
    overflow: visible;
    border-radius: 8px;
    transition: filter 0.2s ease;
  }

  @media (hover: hover) {
    .WideSupportCard:hover { filter: brightness(0.95); }
  }
  .WideSupportCard[data-touch-hover] { filter: brightness(0.95); }

  .WideSupportCard__image-zone {
    flex: 0 0 60%;
    overflow: hidden;
    border-radius: 6px 6px 0 0;
  }

  .WideSupportCard__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
    transition: transform 0.35s ease;
  }

  @media (hover: hover) {
    .WideSupportCard:hover .WideSupportCard__image { transform: scale(1.03); }
  }
  .WideSupportCard[data-touch-hover] .WideSupportCard__image { transform: scale(1.03); }

  .WideSupportCard__body {
    flex: 0 0 40%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0.8rem 1.8rem 0.75rem;
    overflow: visible;
    position: relative;
    container-type: inline-size;
  }

  .WideSupportCard__category {
    position: absolute;
    top: 0;
    left: 1.25rem;
    transform: translateY(-50%);
    display: inline-block;
    background: #ffffff;
    color: var(--color-brand-dark);
    font-family: var(--font-alumni);
    font-size: clamp(0.85rem, 2.5vw, 1.7rem);
    font-weight: 700;
    padding: 0rem 0.7rem;
    border-radius: 9999px;
    line-height: 1.2;
    border: 2px solid var(--color-brand-dark);
    white-space: nowrap;
    z-index: 1;
  }

  .WideSupportCard__title {
    font-family: var(--font-alumni);
    font-weight: 900;
    font-size: clamp(2.2rem, 14cqi, 8rem);
    line-height: 0.88;
    margin: 0;
    color: var(--color-brand-dark);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 1024px) {
    .WideSupportCard__body  { padding: 0.8rem 1.2rem 0.5rem; }
    .WideSupportCard__title { font-size: clamp(3rem, 14cqi, 8rem); line-height: 0.88; }
  }

  @media (max-width: 640px) {
    .WideSupportCard__body  { padding: 0.8rem 0.75rem 0.4rem; }
    .WideSupportCard__title { font-size: clamp(3.2rem, 14cqi, 8rem); line-height: 0.88; }
  }
</style>
