---
/**
 * Cintillo de noticias de última hora.
 * Animación CSS pura — cero JavaScript.
 * Los items se duplican para que el loop sea continuo.
 */
interface Props {
  items: string[];
}

const { items } = Astro.props;
// Triplicamos para garantizar scroll continuo sin gaps
const loopedItems = [...items, ...items, ...items];
---

<div class="flex items-stretch overflow-hidden h-9">

  <!-- Badge fijo "ESTÁ PASANDO" -->
  <div class="flex items-center justify-center px-5 bg-brand-red shrink-0">
    <span class="font-boldonse text-sm text-brand-white uppercase leading-none whitespace-nowrap">
      ESTÁ PASANDO
    </span>
  </div>

  <!-- Track scrolleable -->
<div class="flex-1 overflow-hidden flex items-center bg-brand-green">
  <div class="ticker-track flex items-center gap-4 whitespace-nowrap">
    {loopedItems.map((item) => (
      <>
        <span class="font-bowlby text-brand-black text-sm font-bold uppercase">
          {item}
        </span>
        <span class="text-brand-black font-bold" aria-hidden="true">·</span>
      </>
    ))}
  </div>
</div>
</div>

<style>
  .ticker-track {
    animation: ticker-scroll 30s linear infinite;
  }

  @keyframes ticker-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-33.333%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ticker-track {
      animation: none;
    }
  }
</style>
