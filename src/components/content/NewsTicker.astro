---
/**
 * Cintillo de noticias de última hora.
 * Animación CSS pura — cero JavaScript.
 * Los items se duplican para que el loop sea continuo.
 */
interface Props {
  items: string[];
}

const { items } = Astro.props;
// Triplicamos para garantizar scroll continuo sin gaps
const loopedItems = [...items, ...items, ...items];
---

<div class="flex items-stretch overflow-hidden h-6 lg:h-8">

  <!-- Badge fijo "ESTÁ PASANDO" -->
  <div class="flex items-center justify-center px-2 lg:px-3 bg-brand-red shrink-0">
    <span class="font-boldonse text-[10px] lg:text-xs text-brand-white uppercase leading-none whitespace-nowrap">
      ESTÁ PASANDO
    </span>
  </div>

  <!-- Track scrolleable -->
<div class="flex-1 overflow-hidden flex items-center bg-brand-yellow">
  <div class="ticker-track flex items-center gap-1.5 whitespace-nowrap">
    {loopedItems.map((item) => (
      <>
        <span class="font-barlow font-black uppercase text-brand-dark text-[12px] lg:text-[15px] leading-none lg:leading-4.5 tracking-[-0.02em]">
          {item}
        </span>
        <span class="text-brand-black font-bold" aria-hidden="true">·</span>
      </>
    ))}
  </div>
</div>
</div>

<style>
  @keyframes ticker-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(var(--ticker-shift, -33.333%)); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ticker-track { animation: none !important; }
  }
</style>

<script>
  const TICKER_SPEED = 65; // px/s — igual que HeroCard ticker
  const REPS = 3;

  function calibrate() {
    document.querySelectorAll<HTMLElement>('.ticker-track').forEach(track => {
      const oneRepWidth = track.scrollWidth / REPS;
      const duration = oneRepWidth / TICKER_SPEED;
      track.style.setProperty('--ticker-shift', `${-(100 / REPS)}%`);
      track.style.animation = `ticker-scroll ${duration}s linear infinite`;
    });
  }

  let resizeTimer: ReturnType<typeof setTimeout>;
  document.addEventListener('DOMContentLoaded', calibrate);
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(calibrate, 150);
  });
</script>
