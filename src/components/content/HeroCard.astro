---
import { Image } from 'astro:assets';
import { getPlaceholder } from '@/lib/placeholders';

interface Props {
  title: string;
  slug: string;
  categoryTitle?: string | null;
  imageUrl?: string | null;
  imageAlt?: string;
  tickerText?: string | null;
  highlightWord?: string | null;
}

const { title, slug, categoryTitle, imageUrl, imageAlt = title, tickerText, highlightWord } = Astro.props;

// Triplicamos para scroll continuo sin saltos
const tickerReps = tickerText ? [tickerText, tickerText, tickerText, tickerText, tickerText] : [];

// Partir el título en [antes, palabra destacada, después]
type TitlePart = { text: string; highlight: boolean };
let titleParts: TitlePart[] = [];
if (highlightWord) {
  const lower = title.toLowerCase();
  const idx = lower.indexOf(highlightWord.toLowerCase());
  if (idx !== -1) {
    titleParts = [
      { text: title.slice(0, idx), highlight: false },
      { text: title.slice(idx, idx + highlightWord.length), highlight: true },
      { text: title.slice(idx + highlightWord.length), highlight: false },
    ].filter((p) => p.text.length > 0);
  }
}
if (titleParts.length === 0) {
  titleParts = [{ text: title, highlight: false }];
}
---

<a href={`/${slug}`} class="HeroCard">

  <!-- Mitad superior: ticker animado + imagen -->
  <!-- position: relative para anclar el badge en la línea divisoria -->
  <div class="HeroCard__top">
    {tickerText && (
      <div class="HeroCard__ticker" aria-label="Sumario">
        <div class="HeroCard__ticker-track">
          {tickerReps.map((text) => (
            <>
              <span>{text}</span>
              <span class="HeroCard__ticker-sep" aria-hidden="true">·</span>
            </>
          ))}
        </div>
      </div>
    )}
    <div class="HeroCard__image-zone">
      {imageUrl
        ? <Image src={imageUrl} alt={imageAlt} width={640} height={480} loading="lazy" decoding="async" class="HeroCard__image" />
        : <Image src={getPlaceholder(categoryTitle)} alt={imageAlt} width={640} height={480} loading="lazy" decoding="async" class="HeroCard__image" />
      }
    </div>
  </div>

  <!-- Badge posicionado en la línea divisoria entre imagen y teal -->
  {categoryTitle && (
    <span class="HeroCard__category">{categoryTitle}</span>
  )}

  <!-- Mitad inferior: fondo teal — título desde arriba -->
  <div class="HeroCard__body">
    <h2 class="HeroCard__title">
      {titleParts.map((part) =>
        part.highlight
          ? <span class="HeroCard__title--highlight">{part.text}</span>
          : <span>{part.text}</span>
      )}
    </h2>
  </div>

</a>

<style>
  .HeroCard {
    display: grid;
    grid-template-rows: 1fr 1fr;
    height: 100%;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    position: relative;
  }

  /* ── Mitad superior: ticker + imagen ───────────────────────────── */
  .HeroCard__top {
    display: flex;
    flex-direction: column;
    min-height: 0;
    overflow: hidden;
    position: relative;
  }

  /* Ticker fino animado */
  .HeroCard__ticker {
    flex-shrink: 0;
    height: 1.5rem;
    background: var(--color-brand-green);
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .HeroCard__ticker-track {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    white-space: nowrap;
    font-family: var(--font-franklin);
    font-size: 0.9rem;
    font-weight: 900;
    text-transform: uppercase;
    color: var(--color-brand-dark);
  }

  .HeroCard__ticker-sep {
    opacity: 0.4;
  }

  @keyframes hero-ticker {
    from { transform: translateX(0); }
    to   { transform: translateX(var(--ticker-shift, -20%)); }
  }

  @media (prefers-reduced-motion: reduce) {
    .HeroCard__ticker-track { animation: none; }
  }

  .HeroCard__image-zone {
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  .HeroCard__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 50%;
    display: block;
    transition: transform 0.35s ease;
  }

  .HeroCard:hover .HeroCard__image {
    transform: scale(1.03);
  }

  /* ── Mitad inferior: fondo teal — badge sobre línea + título centrado ─ */
  .HeroCard__body {
    background: var(--color-brand-teal);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding: 1.5rem 3rem 1.5rem;
    gap: 0.4rem;
    overflow: hidden;
    container-type: inline-size;
  }

  /* Badge en la línea divisoria, relativo al card completo */
  .HeroCard__category {
    position: absolute;
    top: 50%;
    left: 0.75rem;
    transform: translateY(-50%);
    display: inline-block;
    background: #ffffff;
    color: var(--color-brand-dark);
    font-family: var(--font-alumni);
    font-size: 1.7rem;
    font-weight: 700;
    padding: 0rem 0.7rem;
    border-radius: 9999px;
    line-height: 1.2;
    border: 2px solid var(--color-brand-dark);
    white-space: nowrap;
    z-index: 10;
  }

  .HeroCard__title {
    font-family: var(--font-alumni);
    font-weight: 900;
    font-size: clamp(3.5rem, 22cqi, 16rem);
    line-height: 0.85;
    color: var(--color-brand-dark);
    margin: 0;
    text-align: left;
    transition: opacity 0.2s ease;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Palabra destacada: más grande que el resto */
  .HeroCard__title--highlight {
    font-size: 1.35em;
    line-height: 0.78;
  }

</style>

<script>
  const TICKER_SPEED = 65; // px/s
  const REPS = 5;          // debe coincidir con tickerReps.length

  function calibrateTickers() {
    document.querySelectorAll<HTMLElement>('.HeroCard__ticker-track').forEach(track => {
      const oneRepWidth = track.scrollWidth / REPS;
      const duration = oneRepWidth / TICKER_SPEED;
      const shift = `${-(100 / REPS)}%`;

      // Aplicar la animación completa de una vez — no modifica una animación en curso
      track.style.setProperty('--ticker-shift', shift);
      track.style.animation = `hero-ticker ${duration}s linear infinite`;
    });
  }

  let resizeTimer: ReturnType<typeof setTimeout>;
  function onResize() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(calibrateTickers, 150);
  }

  document.addEventListener('DOMContentLoaded', calibrateTickers);
  window.addEventListener('resize', onResize);
</script>
