---
const PLACEHOLDER = '/images/placeholder-default.png';

interface Props {
  title: string;
  slug: string;
  categoryTitle?: string | null;
  imageUrl?: string | null;
  imageAlt?: string;
  tickerText?: string | null;
}

const { title, slug, categoryTitle, imageUrl, imageAlt = title, tickerText } = Astro.props;
const src = imageUrl ?? PLACEHOLDER;
// Triplicamos para scroll continuo sin saltos
const tickerReps = tickerText ? [tickerText, tickerText, tickerText] : [];
---

<a href={`/${slug}`} class="HeroCard">

  <!-- Mitad superior: ticker animado + imagen -->
  <div class="HeroCard__top">
    {tickerText && (
      <div class="HeroCard__ticker" aria-label="Sumario">
        <div class="HeroCard__ticker-track">
          {tickerReps.map((text, i) => (
            <>
              <span>{text}</span>
            </>
          ))}
        </div>
      </div>
    )}
    <div class="HeroCard__image-zone">
      <img
        src={src}
        alt={imageAlt}
        width="640"
        height="480"
        loading="lazy"
        decoding="async"
        class="HeroCard__image"
      />
    </div>
  </div>

  <!-- Mitad inferior: fondo teal, badge + título -->
  <div class="HeroCard__body">
    {categoryTitle && (
      <span class="HeroCard__category">{categoryTitle}</span>
    )}
    <h2 class="HeroCard__title">{title}</h2>
  </div>

</a>

<style>
  .HeroCard {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
  }

  /* ── Mitad superior: ticker + imagen (50% altura) ──────────────── */
  .HeroCard__top {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
    overflow: hidden;
  }

  /* Ticker fino, sin badge, solo scroll de texto */
  .HeroCard__ticker {
    flex-shrink: 0;
    height: 1.5rem;
    background: var(--color-brand-green);
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .HeroCard__ticker-track {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    white-space: nowrap;
    font-family: var(--font-franklin);
    font-size: 0.9rem;
    font-weight: 900;
    text-transform: uppercase;
    color: var(--color-brand-black);
    animation: hero-ticker 25s linear infinite;
  }

  .HeroCard__ticker-sep {
    opacity: 0.5;
  }

  @keyframes hero-ticker {
    from { transform: translateX(0); }
    to   { transform: translateX(-33.333%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .HeroCard__ticker-track { animation: none; }
  }

  .HeroCard__image-zone {
    flex: 1;
    min-height: 0;
    overflow: hidden;
  }

  .HeroCard__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .HeroCard:hover .HeroCard__image {
    transform: scale(1.03);
  }

  /* ── Mitad inferior: fondo teal, badge + título (50% altura) ───── */
  .HeroCard__body {
    flex: 1;
    background: var(--color-brand-teal);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0.75rem 0.75rem 1rem;
    gap: 0.4rem;
    overflow: hidden;
  }

  .HeroCard__category {
    display: inline-block;
    align-self: flex-start;
    background: #ffffff;
    color: var(--color-brand-dark);
    font-family: var(--font-barlow);
    font-size: 0.68rem;
    font-weight: 600;
    padding: 0.2rem 0.75rem;
    border-radius: 9999px;
    line-height: 1.4;
    border: 1.5px solid var(--color-brand-dark);
  }

  .HeroCard__title {
    font-family: var(--font-alumni);
    font-weight: 900;
    font-size: clamp(3rem, 9vw, 9rem);
    line-height: 0.88;
    color: var(--color-brand-dark);
    margin: 0;
    transition: opacity 0.2s ease;
  }

  .HeroCard:hover .HeroCard__title {
    opacity: 0.8;
  }
</style>
