---
import { getImageUrl } from '@/lib/cms';
import AdCard from './AdCard.astro';
import type { AdLike } from '@/sections/home/mocks/newsGridMock';

interface Props {
  ads: AdLike[];
}

const { ads } = Astro.props;

function imgUrl(ad: AdLike, width: number): string | null {
  if (!ad.data.image) return null;
  try {
    return getImageUrl(ad.data.image as Parameters<typeof getImageUrl>[0], { width });
  } catch {
    return null;
  }
}
---

{ads.length > 0 && (
  <section class="AdsBand2" aria-label="Espacios publicitarios" style={`--count: ${Math.min(ads.length, 4)}`}>
    {ads.slice(0, 4).map((ad) => (
      <div class="AdsBand2__item">
        <AdCard
          title={ad.data.title}
          brand={ad.data.brand ?? null}
          imageUrl={imgUrl(ad, 320)}
          imageAlt={ad.data.image?.alt ?? ad.data.brand ?? ad.data.title}
          url={ad.data.url ?? null}
          size="equal"
        />
      </div>
    ))}
  </section>
)}

<style>
  .AdsBand2 {
    display: grid;
    grid-template-columns: repeat(var(--count, 4), 1fr);
    gap: 6px;
    border-radius: 10px;
    overflow: hidden;
    height: 240px;
  }

  .AdsBand2__item {
    border-radius: 8px;
    overflow: hidden;
    height: 100%;
  }

  /* ── Tablet ── */
  @media (max-width: 1024px) and (min-width: 641px) {
    .AdsBand2 { height: 200px; }
  }

  /* ── Mobile: 2 columnas, 2 filas ── */
  @media (max-width: 640px) {
    .AdsBand2 {
      grid-template-columns: 1fr 1fr;
      height: auto;
    }

    .AdsBand2__item { height: 160px; }
  }
</style>
