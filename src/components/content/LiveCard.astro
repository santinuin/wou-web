---
import RadioPlayer from '@/components/ui/RadioPlayer.svelte';
import RadioWaves from '@/components/ui/RadioWaves.svelte';

interface Props {
  isLive: boolean;
  streamUrl?: string | null;
}

const { isLive, streamUrl } = Astro.props;
---

<!--
  container-type: inline-size → permite usar `cqw` (% del ancho de la card)
  como unidad de tipografía. Así el "EN VIVO" y el ⦿ escalan con la card,
  ocupando un % constante del ancho disponible en mobile, tablet y desktop.
-->
<div class="relative flex flex-col h-full bg-brand-dark overflow-hidden" style="container-type: inline-size;">

  <!-- EN VIVO — tamaño relativo al ancho de la card -->
  <div class="flex items-center justify-center gap-2 shrink-0 pt-2 lg:pt-0">
    <span
      class="text-brand-red leading-none"
      style="font-size: clamp(1.5rem, 16cqw, 4rem);"
      aria-hidden="true"
    >⦿</span>
    <span
      class="font-bowlby text-brand-red uppercase leading-none tracking-tight whitespace-nowrap"
      style="font-size: clamp(1.5rem, 16cqw, 4rem);"
    >
      {isLive ? 'EN VIVO' : 'EN VIVO'}
    </span>
  </div>

  <!-- Ondas de radio -->
  <div class="flex-1 min-h-0 py-3">
    <RadioWaves client:idle />
  </div>

  <!-- Mute -->
  <div class="shrink-0 ml-auto mr-4">
    {streamUrl ? (
      <RadioPlayer streamUrl={streamUrl} client:idle />
    ) : (
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F0EDE8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-label="Sin stream configurado">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
        <line x1="23" y1="9" x2="17" y2="15"/>
        <line x1="17" y1="9" x2="23" y2="15"/>
      </svg>
    )}
  </div>

</div>
