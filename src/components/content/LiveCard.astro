---
import RadioPlayer from '@/components/ui/RadioPlayer.svelte';

interface Props {
  isLive: boolean;
  station: string;
  description: string;
  streamUrl?: string | null;
}

const { isLive, station, description, streamUrl } = Astro.props;
---

<div class="relative flex flex-col h-full bg-brand-black overflow-hidden p-5 pr-0 pb-0">

  <!-- Estado EN VIVO + nombre de estación -->
  <div class="flex items-center justify-between shrink-0">
    <div class="flex items-center gap-2">
      {isLive && (
        <span class="flex items-center gap-1.5">
          <span class="w-2 h-2 rounded-full bg-red-500 animate-pulse" aria-hidden="true" />
          <span class="font-bowlby text-xs text-red-400 uppercase tracking-widest">En vivo</span>
        </span>
      )}
      <span class="font-bowlby text-brand-white text-sm uppercase tracking-widest">
        {station}
      </span>
    </div>
  </div>

  <!-- Descripción -->
  <p class="font-sans text-brand-white/70 text-xs leading-relaxed mt-3 max-w-[200px] shrink-0">
    {description}
  </p>

  <!-- Decoración: ondas de radio (SVG estático) -->
  <div class="flex-1 flex items-end pb-1 opacity-80" aria-hidden="true">
    <svg
      viewBox="0 0 300 120"
      preserveAspectRatio="none"
      class="w-full h-full"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path d="M0 15 C50 13, 100 13, 150 15 C200 17, 250 17, 300 15" stroke="#00C9B1" stroke-width="1.2" opacity="0.4"/>
      <path d="M0 27 C50 23, 100 23, 150 27 C200 31, 250 31, 300 27" stroke="#00C9B1" stroke-width="1.2" opacity="0.5"/>
      <path d="M0 39 C50 33, 100 33, 150 39 C200 45, 250 45, 300 39" stroke="#00C9B1" stroke-width="1.3" opacity="0.55"/>
      <path d="M0 52 C50 44, 100 44, 150 52 C200 60, 250 60, 300 52" stroke="#00C9B1" stroke-width="1.4" opacity="0.6"/>
      <path d="M0 65 C50 54, 100 54, 150 65 C200 76, 250 76, 300 65" stroke="#00C9B1" stroke-width="1.5" opacity="0.65"/>
      <path d="M0 79 C50 66, 100 66, 150 79 C200 92, 250 92, 300 79" stroke="#00C9B1" stroke-width="1.6" opacity="0.75"/>
      <path d="M0 93 C50 77, 100 77, 150 93 C200 109, 250 109, 300 93" stroke="#00C9B1" stroke-width="1.7" opacity="0.85"/>
      <path d="M0 108 C50 89, 100 89, 150 108 C200 127, 250 127, 300 108" stroke="#00C9B1" stroke-width="1.8" opacity="1"/>
    </svg>
  </div>

  <!-- Botón mute — island Svelte (solo este botón tiene JS) -->
  <div class="absolute bottom-4 right-4">
    {streamUrl ? (
      <RadioPlayer streamUrl={streamUrl} client:idle />
    ) : (
      <!-- Sin stream configurado: ícono estático -->
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f0f4f8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="opacity-40">
        <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
        <line x1="23" y1="9" x2="17" y2="15"/>
        <line x1="17" y1="9" x2="23" y2="15"/>
      </svg>
    )}
  </div>
</div>
