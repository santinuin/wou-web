---
const PLACEHOLDER = '/images/placeholder-default.png';

interface Props {
  title: string;
  slug: string;
  categoryTitle?: string | null;
  imageUrl?: string | null;
  imageAlt?: string;
  wide?: boolean;
}

const { title, slug, categoryTitle, imageUrl, imageAlt = title } = Astro.props;
const src = imageUrl ?? PLACEHOLDER;
---

<a href={`/${slug}`} class="SupportCard" aria-label={title}>
  <div class="SupportCard__image-zone">
    <img
      src={src}
      alt={imageAlt}
      width="560"
      height="360"
      loading="lazy"
      decoding="async"
      class="SupportCard__image"
    />
  </div>

  <div class="SupportCard__body">
    {categoryTitle && (
      <span class="SupportCard__category">{categoryTitle}</span>
    )}
    <h3 class="SupportCard__title">{title}</h3>
  </div>
</a>

<style>
  .SupportCard {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: #ffffff;
    text-decoration: none;
    color: var(--color-brand-dark);
    overflow: hidden;
    transition: filter 0.2s ease;
  }

  .SupportCard:hover {
    filter: brightness(0.95);
  }

  /* Image takes exactly half the card height */
  .SupportCard__image-zone {
    flex: 0 0 50%;
    overflow: hidden;
  }

  .SupportCard__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .SupportCard:hover .SupportCard__image {
    transform: scale(1.03);
  }

  /* White text area — badge + title */
  .SupportCard__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.55rem 0.75rem 0.75rem;
    overflow: hidden;
  }

  /* White pill with visible border (on white background) */
  .SupportCard__category {
    display: inline-block;
    align-self: flex-start;
    flex-shrink: 0;
    background: #ffffff;
    color: var(--color-brand-dark);
    font-family: var(--font-barlow);
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.18rem 0.65rem;
    border-radius: 9999px;
    line-height: 1.4;
    border: 1.5px solid var(--color-brand-dark);
  }

  .SupportCard__title {
    font-family: var(--font-alumni);
    font-weight: 900;
    font-size: clamp(2rem, 3.5vw, 3.5rem);
    line-height: 0.92;
    margin: 0;
    color: var(--color-brand-dark);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
