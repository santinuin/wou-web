---
import { Image } from 'astro:assets';
import { getPlaceholder } from '@/lib/placeholders';

interface Props {
  title: string;
  slug: string;
  categoryTitle?: string | null;
  imageUrl?: string | null;
  imageAlt?: string;
  wide?: boolean;
}

const { title, slug, categoryTitle, imageUrl, imageAlt = title } = Astro.props;
---

<a href={`/articulo/${slug}`} class="SupportCard" aria-label={title}>
  <div class="SupportCard__image-zone">
    {imageUrl
      ? <Image src={imageUrl} alt={imageAlt} width={560} height={360} loading="lazy" decoding="async" class="SupportCard__image" />
      : <Image src={getPlaceholder(categoryTitle)} alt={imageAlt} width={560} height={360} loading="lazy" decoding="async" class="SupportCard__image" />
    }
  </div>

  <div class="SupportCard__body">
    {categoryTitle && (
      <span class="SupportCard__category">{categoryTitle}</span>
    )}
    <h3 class="SupportCard__title">{title}</h3>
  </div>
</a>

<style is:global>
  .SupportCard {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: #ffffff;
    text-decoration: none;
    color: var(--color-brand-dark);
    overflow: visible;
    transition: filter 0.2s ease;
  }

  @media (hover: hover) {
    .SupportCard:hover { filter: brightness(0.95); }
  }
  .SupportCard[data-touch-hover] { filter: brightness(0.95); }

  /* Image takes exactly half the card height */
  .SupportCard__image-zone {
    flex: 0 0 55%;
    overflow: hidden;
  }

  .SupportCard__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
    transition: transform 0.35s ease;
  }

  @media (hover: hover) {
    .SupportCard:hover .SupportCard__image { transform: scale(1.03); }
  }
  .SupportCard[data-touch-hover] .SupportCard__image { transform: scale(1.03); }

  /* White text area — badge sobre línea + title */
  .SupportCard__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.35rem;
    padding: 0.8rem 1rem 0.75rem;
    overflow: visible;
    position: relative;
  }

  /* Badge centrado sobre la línea divisoria — mismo estilo que HeroCard */
  .SupportCard__category {
    position: absolute;
    top: 0;
    left: 0.75rem;
    transform: translateY(-50%);
    display: inline-block;
    background: #ffffff;
    color: var(--color-brand-dark);
    font-family: var(--font-alumni);
    font-size: clamp(0.85rem, 2.5vw, 1.7rem);
    font-weight: 700;
    padding: 0rem 0.7rem;
    border-radius: 9999px;
    line-height: 1.2;
    border: 2px solid var(--color-brand-dark);
    white-space: nowrap;
    z-index: 1;
  }

  .SupportCard__title {
    font-family: var(--font-alumni);
    font-weight: 900;
    font-size: clamp(2.2rem, 4vw, 4rem);
    line-height: 0.7;
    margin: 0;
    color: var(--color-brand-dark);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    hyphens: auto;
    overflow-wrap: break-word;
  }

  @media (max-width: 1024px) {
    .SupportCard__body  { padding: 0.8rem 0.75rem 0.5rem; }
    .SupportCard__title { font-size: clamp(2.6rem, 4vw, 4rem); line-height: 0.70; }
  }

  @media (max-width: 640px) {
    .SupportCard__body  { padding: 0.8rem 0.6rem 0.4rem; }
    .SupportCard__title { font-size: clamp(3rem, 4vw, 4rem); line-height: 0.68; }
  }
</style>
