---
import { Image } from 'astro:assets';
import editorialBadge from '@/assets/editorial-semanal.png';

interface Props {
  title: string;
  highlightWord?: string | null;
  imageUrl?: string | null;
  imageAlt?: string;
  slug: string;
}

const { title, highlightWord, imageUrl, imageAlt = 'Imagen editorial', slug } = Astro.props;

// Divide el título en partes para destacar la palabra clave
const titleParts = highlightWord
  ? title.split(new RegExp(`(${highlightWord})`, 'gi'))
  : [title];
---

<a
  href={`/editorial/${slug}`}
  class="EditorialCard"
  aria-label={`Leer editorial: ${title}`}
>
  <!-- Cursor SVG personalizado -->
  <div class="EC__cursor" aria-hidden="true">
    <svg width="23" height="25" viewBox="0 0 23 25" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M21.9431 9.77477L1.42821 0.0979468C0.658599 -0.265079 -0.183895 0.437835 0.0353599 1.26004L6.12016 24.078C6.40475 25.1452 7.95452 25.0313 8.07993 23.9339L9.37916 12.5657C9.43688 12.0606 9.86434 11.6792 10.3727 11.6792H21.5165C22.5841 11.6792 22.9087 10.2303 21.9431 9.77477Z" fill="#01236A"/>
    </svg>
  </div>

  <!-- Badge "EDITORIAL SEMANAL" que sigue al cursor -->
  <div class="EC__badge" aria-hidden="true">
    <Image
      src={editorialBadge}
      alt=""
      width={160}
      loading="eager"
    />
  </div>

  <!-- Imagen: misma altura que LiveCard+YT, recortada desde arriba -->
  <div class="EC__image">
    {imageUrl ? (
      <img
        src={imageUrl}
        alt={imageAlt}
        class="w-full h-full object-cover object-top"
        loading="eager"
        fetchpriority="high"
      />
    ) : (
      <div class="w-full h-full bg-brand-teal/40" />
    )}
  </div>

  <!-- Título: llena el área teal disponible -->
  <div class="EC__title-wrap">
    <h2 class="EC__title font-alumni font-extrabold leading-none">
      {titleParts.map((part, i) =>
        i % 2 === 1
          ? <em class="EC__highlight">{part}</em>
          : <>{part}</>
      )}
    </h2>
  </div>
</a>

<style>
  .EditorialCard {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    background: var(--color-brand-teal);
    text-decoration: none;
    overflow: hidden;
    position: relative;
    cursor: none;
  }

  /* ── Cursor personalizado ─────────────────────────────────────────── */
  .EC__cursor,
  .EC__badge {
    display: none; /* oculto en mobile */
  }

  @media (min-width: 1024px) {
    .EC__cursor,
    .EC__badge {
      display: block;
      position: fixed;
      top: 0;
      left: 0;
      pointer-events: none;
      opacity: 0;
      z-index: 9999;
      transition: opacity 0.12s ease;
      will-change: transform;
    }

    /* opacidad controlada por JS para que el scroll la resetee */
  }

  /* ── Imagen ───────────────────────────────────────────────────────── */
  .EC__image {
    width: 100%;
    height: 260px; /* mobile/tablet: altura fija */
    flex-shrink: 0;
    overflow: hidden;
  }

  @media (min-width: 1024px) {
    .EC__image {
      /* Alinea con LiveCard+YT (42% del hero) menos el ticker (h-9 = 2.25rem) */
      height: calc(0.42 * (100vh - 5.5rem) - 2.25rem);
    }
  }

  /* ── Título ───────────────────────────────────────────────────────── */
  .EC__title-wrap {
    container-type: inline-size;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.25rem 0.25rem 0.25rem;
    overflow: hidden;
    position: relative;
  }

  .EC__title {
    font-size: 2rem; /* JS lo reemplaza; fallback para SSR */
    line-height: 0.70;
    color: var(--color-brand-dark);
    margin: 0;
    text-align: center;
    width: 100%;
  }


  .EC__highlight {
    font-style: normal;
    font-size: 1.4em;
  }
</style>

<script>
  // ── Cursor personalizado con lerp ─────────────────────────────────────────
  const card   = document.querySelector<HTMLElement>('.EditorialCard');
  const cursor = document.querySelector<HTMLElement>('.EC__cursor');
  const badge  = document.querySelector<HTMLElement>('.EC__badge');

  if (card && cursor && badge) {
    let mouseX = 0, mouseY = 0;
    let badgeX = 0, badgeY = 0;
    const LERP = 0.08;

    const show = () => { cursor.style.opacity = '1'; badge.style.opacity = '1'; };
    const hide = () => { cursor.style.opacity = '0'; badge.style.opacity = '0'; };

    card.addEventListener('mouseenter', show);
    card.addEventListener('mouseleave', hide);
    window.addEventListener('scroll', () => {
      const r = card.getBoundingClientRect();
      const inside = mouseX >= r.left && mouseX <= r.right && mouseY >= r.top && mouseY <= r.bottom;
      if (!inside) hide();
    }, { passive: true });

    card.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      cursor.style.transform = `translate(${mouseX}px, ${mouseY}px)`;
    });

    (function loop() {
      badgeX += (mouseX + 12 - badgeX) * LERP;
      badgeY += (mouseY + 6 - badgeY) * LERP;
      badge.style.transform = `translate(${badgeX}px, ${badgeY}px)`;
      requestAnimationFrame(loop);
    })();
  }

  // ── Fit text: binary search del font-size máximo que cabe en el área teal ─
  const wrap  = document.querySelector<HTMLElement>('.EC__title-wrap');
  const title = document.querySelector<HTMLElement>('.EC__title');

  function fitTitle() {
    if (!wrap || !title) return;
    let lo = 16, hi = 500;
    // Busca el mayor tamaño donde scrollHeight ≤ clientHeight del wrapper
    while (hi - lo > 0.5) {
      const mid = (lo + hi) / 2;
      title.style.fontSize = `${mid}px`;
      title.scrollHeight <= wrap.clientHeight ? (lo = mid) : (hi = mid);
    }
    title.style.fontSize = `${Math.floor(lo)}px`;
  }

  document.fonts.ready.then(fitTitle);
  if (wrap) new ResizeObserver(fitTitle).observe(wrap);
</script>
