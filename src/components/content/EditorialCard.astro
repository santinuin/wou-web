---
/**
 * Bloque editorial semanal — columna derecha del Hero.
 * Fondo teal, badge oscuro, imagen + pregunta + título gigante.
 */
interface Props {
  title: string;
  question: string;
  imageUrl?: string | null;
  imageAlt?: string;
  slug: string;
}

const { title, question, imageUrl, imageAlt = 'Imagen editorial', slug } = Astro.props;
---

<a
  href={`/editorial/${slug}`}
  class="flex flex-col h-full bg-brand-teal p-6 hover:brightness-105 transition-all group"
  aria-label={`Leer editorial: ${title}`}
>
  <!-- Zona superior: badge + imagen -->
  <div class="flex items-start justify-between gap-4 shrink-0">

    <!-- Badge "EDITORIAL SEMANAL" -->
    <div class="bg-brand-dark text-brand-white px-3 py-2 shrink-0">
      <span class="font-barlow font-black text-sm uppercase tracking-wide leading-tight block">
        Editorial<br />Semanal
      </span>
    </div>

    <!-- Imagen destacada (ocupa el resto del ancho) -->
    <div class="flex-1 max-w-[55%]">
      {imageUrl ? (
        <img
          src={imageUrl}
          alt={imageAlt}
          width="380"
          height="260"
          class="w-full h-auto object-cover rounded-lg"
          loading="eager"
        />
      ) : (
        <!-- Placeholder hasta que el CMS tenga imagen -->
        <div class="w-full aspect-video bg-brand-dark/20 rounded-lg flex items-center justify-center">
          <span class="font-sans text-brand-dark/40 text-xs">Sin imagen</span>
        </div>
      )}
    </div>
  </div>

  <!-- Pregunta / Bajada -->
  <p class="font-sans text-brand-dark text-base leading-snug mt-5 max-w-65 shrink-0">
    {question}
  </p>

  <!-- Título gigante — ocupa el espacio restante -->
  <div class="flex-1 flex items-end">
    <h2 class="font-bowlby text-brand-white uppercase leading-none text-[clamp(3rem,6vw,5.5rem)] group-hover:text-brand-dark/90 transition-colors">
      {title}
    </h2>
  </div>
</a>
