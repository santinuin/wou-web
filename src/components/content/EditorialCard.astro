---
/**
 * Bloque editorial semanal — columna derecha del Hero.
 *
 * Se posiciona como subgrilla dentro del Hero (grid-rows-subgrid), ocupando
 * las 3 filas del padre (row-span-3). Así comparte las líneas horizontales
 * con la columna izquierda:
 *
 *   Fila 1 (1fr):  badge + bajada | imagen   ←→  LiveCard + YT
 *   Fila 2 (auto): (vacía, fondo teal)        ←→  Ticker
 *   Fila 3 (1fr):  título gigante             ←→  NewsList
 *
 * ⇒ el piso de la imagen y la bajada queda exactamente al nivel del piso
 *   de LiveCard/YoutubeEmbed.
 *
 * Nota: el padding se aplica en los wrappers de cada fila (no en <a>) para
 * que las líneas de la subgrilla coincidan con las del padre sin desfase.
 */
interface Props {
  title: string;
  question: string;
  imageUrl?: string | null;
  imageAlt?: string;
  slug: string;
}

const { title, question, imageUrl, imageAlt = 'Imagen editorial', slug } = Astro.props;
---

<a
  href={`/editorial/${slug}`}
  class="col-start-2 row-start-1 row-span-3 grid grid-rows-subgrid bg-brand-teal hover:brightness-105 transition-all group"
  aria-label={`Leer editorial: ${title}`}
>
  <!-- ── Fila 1: badge + bajada (izq) | imagen (der) ──────────────────────── -->
  <!-- items-stretch por defecto: ambas columnas llenan la altura de la fila. -->
  <!-- justify-between en la col izq → badge arriba, bajada pegada al piso.   -->
  <div class="row-start-1 flex gap-6 px-6 pt-6 min-h-0">

    <!-- Columna izquierda: badge arriba, bajada abajo -->
    <div class="flex flex-col justify-between gap-4 min-w-0" style="max-width: 42%">

      <!-- Badge rotado ligeramente -->
      <div class="bg-brand-dark text-brand-white px-4 py-2 w-fit rotate-3 shrink-0">
        <span class="font-barlow font-black text-base uppercase tracking-wide leading-tight block">
          Editorial<br />Semanal
        </span>
      </div>

      <!-- Bajada: Libre Franklin Bold, blanca, ~20px -->
      <p class="font-franklin font-bold text-brand-white text-xl leading-snug">
        {question}
      </p>
    </div>

    <!-- Columna derecha: imagen (llena el alto de la fila) -->
    <div class="flex-1 min-h-0 min-w-0">
      {imageUrl ? (
        <img
          src={imageUrl}
          alt={imageAlt}
          width="380"
          height="260"
          class="w-full h-full object-cover"
          loading="eager"
        />
      ) : (
        <div class="w-full h-full bg-brand-dark/20 flex items-center justify-center">
          <span class="font-sans text-brand-dark/40 text-xs">Sin imagen</span>
        </div>
      )}
    </div>
  </div>

  <!-- ── Fila 2: intencionalmente vacía (coincide con el ticker) ──────────── -->
  <!-- El bg-brand-teal del <a> rellena este espacio visualmente. -->

  <!-- ── Fila 3: título Alumni Sans ultra-grande ──────────────────────────── -->
  <div class="row-start-3 flex items-end px-6 pb-6 min-h-0">
    <h2
      class="font-alumni font-black text-brand-white uppercase w-full leading-[0.88] group-hover:text-brand-dark/90 transition-colors"
      style="font-size: clamp(5rem, 11vw, 12rem)"
    >
      {title}
    </h2>
  </div>
</a>
