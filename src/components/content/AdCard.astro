---
interface Props {
  imageUrl?: string | null;
  imageAlt?: string;
  url?: string | null;
  title: string; // para aria-label y alt fallback
}

const { imageUrl, imageAlt = 'Publicidad', url, title } = Astro.props;
---

<a
  href={url ?? '#'}
  class="AdCard"
  target={url ? '_blank' : undefined}
  rel={url ? 'noopener noreferrer sponsored' : undefined}
  aria-label={`Publicidad${title ? ': ' + title : ''}`}
>
  {imageUrl
    ? <img
        src={imageUrl}
        alt={imageAlt}
        loading="lazy"
        decoding="async"
        class="AdCard__image"
      />
    : <div class="AdCard__placeholder" aria-hidden="true"></div>
  }

  <span class="AdCard__badge">Publicidad</span>
</a>

<style>
  .AdCard {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    overflow: hidden;
    text-decoration: none;
    background: color-mix(in oklab, var(--color-brand-dark) 80%, var(--color-brand-blue));
  }

  @media (hover: hover) {
    .AdCard:hover .AdCard__image { transform: scale(1.03); }
  }

  .AdCard__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.4s ease;
  }

  /* Placeholder cuando no hay imagen */
  .AdCard__placeholder {
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(
      -45deg,
      #1c3f8f 0px,
      #1c3f8f 14px,
      #4a90d9 14px,
      #4a90d9 28px
    );
  }

  /* Badge pequeño "PUBLICIDAD" */
  .AdCard__badge {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    font-family: var(--font-barlow);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-brand-dark);
    background: rgba(240, 244, 248, 0.82);
    padding: 0.15em 0.5em;
    border-radius: 9999px;
    backdrop-filter: blur(4px);
    pointer-events: none;
    line-height: 1.6;
  }
</style>
