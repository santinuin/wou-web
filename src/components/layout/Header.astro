        <!-- ! -->
        <path fill-rule="evenodd" clip-rule="evenodd" d="M100.417 3.21201C101.145 2.11484 102.286 1.36749 103.616 0.874558C105.516 0.174912 106.973 0.174912 109 0L108.541 18.811C108.398 24.9806 106.435 26.1095 100.528 26.1095L99.7676 8.72968L99.6568 6.18551C99.6092 5.02473 99.7676 4.19788 100.417 3.21201Z" fill="#F0EDE8"/>
        <path fill-rule="evenodd" clip-rule="evenodd" d="M104.487 27.5249C106.799 27.5249 108.668 29.4012 108.668 31.7228C108.668 34.0443 106.799 35.9207 104.487 35.9207C102.175 35.9207 100.306 34.0443 100.306 31.7228C100.306 29.4012 102.175 27.5249 104.487 27.5249Z" fill="#F0EDE8"/>
      </svg>
    </a>

    <!-- ── Botón secciones ────────────────────────────────────────────── -->
    <!-- TODO: reemplazar por <SectionMenu client:load /> cuando el dropdown esté definido -->
    <button
      type="button"
      class="flex items-center gap-1.5 font-bowlby text-brand-teal uppercase tracking-wide cursor-pointer justify-self-end text-[calc(1.125rem*var(--header-scale,1))] transition-[font-size] duration-300"
      aria-haspopup="true"
      aria-expanded="false"
      aria-label="Ver todas las secciones"
    >
      Secciones
      <!-- flecha ↓ con tallo -->
      <svg
        aria-hidden="true"
        class="w-[calc(8px*var(--header-scale,1))] h-[calc(12px*var(--header-scale,1))] transition-[width,height] duration-300"
        viewBox="0 0 8 12"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <line x1="4" y1="0" x2="4" y2="8" stroke="#00C9B1" stroke-width="2" stroke-linecap="round"/>
        <path d="M1 6L4 11L7 6" stroke="#00C9B1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</header>

<!--
  SectionsMenu: fixed al viewport, mitad derecha, debajo del header (z-[49] < header z-50).
  Visible desde cualquier sección de la página al hacer scroll.
  TODO: pasar getCollection('categories') en vez de MOCK_SECTIONS cuando el CMS esté listo.
-->
<SectionsMenu sections={MOCK_SECTIONS} client:only="svelte" />

<style>
  /* --header-scale: 1 cuando está en reposo, 0.72 al scrollear. Un solo
     toggle de la variable encoge altura, logo, íconos y texto en una sola
     transición coherente. */
  #siteHeader {
    --header-scale: 1;
  }
  #siteHeader.is-scrolled {
    --header-scale: 0.72;
  }

  /* Elementos que solo aparecen en estado scrolled */
  .header-scrolled {
    display: none;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  #siteHeader.is-scrolled .header-scrolled {
    display: flex;
    opacity: 1;
  }

  /* "Viento | " se oculta al scrollear */
  #siteHeader.is-scrolled .header-normal {
    display: none;
  }
</style>

<script>
  // El header queda en tamaño grande únicamente cuando el scroll está
  // exactamente en 0 (tope de la página). Apenas se mueve, encoge.
  const header = document.getElementById('siteHeader');
  if (header) {
    const sync = () => {
      header.classList.toggle('is-scrolled', window.scrollY > 0); //TODO definir si no es 40
    };
    sync();
    window.addEventListener('scroll', sync, { passive: true });
  }

  // Botón Secciones — abre/cierra el panel lateral del Hero
  const sectionsBtn = document.querySelector<HTMLButtonElement>('[aria-label="Ver todas las secciones"]');
  if (sectionsBtn) {
    sectionsBtn.addEventListener('click', () => {
      const opening = sectionsBtn.getAttribute('aria-expanded') !== 'true';
      sectionsBtn.setAttribute('aria-expanded', String(opening));
      window.dispatchEvent(new CustomEvent('sections-menu-toggle'));
    });

    // Sincronizar cuando el menú se cierra con Escape desde SectionsMenu
    window.addEventListener('sections-menu-closed', () => {
      sectionsBtn.setAttribute('aria-expanded', 'false');
    });
  }
</script>
