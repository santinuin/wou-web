---
/**
 * Header principal — versión desktop.
 *
 * Grid de 3 columnas [1fr auto 1fr] para centrado matemático del logo:
 * el punto teal (•) queda en el 50% exacto del viewport,
 * alineado con la división del Hero.
 *   · Col 1 (1fr, left-align)  : indicador de viento
 *   · Col 2 (auto, center)     : logotipo W•U!
 *   · Col 3 (1fr, right-align) : botón "Secciones"
 */
import SectionsMenu from '@/components/ui/SectionsMenu.svelte';
import WindWidget from '@/components/ui/WindWidget.svelte';

// TODO: reemplazar por getCollection('categories') cuando el CMS esté listo.
const MOCK_SECTIONS = [
  { title: 'Círculo Rojo', slug: '/circulo-rojo', color: null },
  { title: 'Política',     slug: '/politica',     color: null },
  { title: 'Locales',      slug: '/locales',      color: null },
  { title: 'Policiales',   slug: '/policiales',   color: null },
  { title: 'Opinión',      slug: '/opinion',      color: null },
  { title: 'Deportes',     slug: '/deportes',     color: null },
  { title: 'Sociedad',     slug: '/sociedad',     color: null },
  { title: 'Cultura',      slug: '/cultura',      color: null },
  { title: 'Economía',     slug: '/economia',     color: null },
  { title: 'Turismo',      slug: '/turismo',      color: null },
  { title: 'Ambiente',     slug: '/ambiente',     color: null },
  { title: 'Nacionales',   slug: '/nacionales',   color: null },
];
---

<!--
  `sticky top-0 z-50`: el header queda visible en todas las secciones al
  scrollear. Cuando el usuario baja más de 40px aplicamos la clase
  `is-scrolled` que reduce altura, logo y texto vía la variable
  `--header-scale` (leída por los elementos internos). Esto mantiene el
  grid matemáticamente centrado aunque los elementos encojan.
-->
<header
  id="siteHeader"
  class="sticky top-0 left-0 right-0 z-50 bg-brand-dark transition-colors duration-300"
>
  <div
    class="w-full px-6 h-[calc(5.5rem*var(--header-scale,1))] grid grid-cols-[1fr_auto_1fr] items-center transition-[height] duration-300"
  >
    <!-- ── Col izquierda ───────────────────────────────────────────────── -->
    <div class="flex items-center gap-2.5">

      <!-- Solo visible en estado scrolled: mute + EN VIVO + estación -->
      <div class="header-scrolled flex items-center gap-2.5">
        <!-- Icono mute/speaker -->
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#F0EDE8" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="transform: translateY(-2px)">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
          <line x1="23" y1="9" x2="17" y2="15"/>
          <line x1="17" y1="9" x2="23" y2="15"/>
        </svg>
        <!-- EN VIVO + estación -->
        <div class="flex items-center gap-2 leading-none">
          <span class="font-bowlby text-brand-red uppercase tracking-tight whitespace-nowrap" style="font-size: 0.7rem;">
            ⦿ EN VIVO
          </span>
          <span class="font-bowlby text-brand-white uppercase tracking-tight whitespace-nowrap" style="font-size: 0.7rem;">
            WOU 95.1
          </span>
        </div>
      </div>

      <!-- Ícono de viento (siempre visible) -->
      <img
        src="/viento.gif"
        alt=""
        aria-hidden="true"
        class="w-[calc(2.75rem*var(--header-scale,1))] h-[calc(2.75rem*var(--header-scale,1))] transition-[width,height] duration-300 object-contain"
      />

      <!-- Texto de viento: "Viento | " se oculta al scrollear -->
      <span
        class="font-bowlby text-brand-teal tracking-wide text-[calc(1rem*var(--header-scale,1))] transition-[font-size] duration-300 whitespace-nowrap"
      >
        <span class="header-normal">Viento | </span><WindWidget client:load />
      </span>
    </div>

    <!-- ── Logotipo W•U! (SVG oficial) ────────────────────────────────── -->
    <a href="/" aria-label="Ir a la portada" class="select-none">
      <svg
        class="w-[calc(180px*var(--header-scale,1))] h-[calc(61px*var(--header-scale,1))] transition-[width,height] duration-300"
        viewBox="0 0 109 37"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        aria-hidden="true"
      >
        <!-- W -->
