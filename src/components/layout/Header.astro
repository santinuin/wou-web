        <!-- U -->
        <path fill-rule="evenodd" clip-rule="evenodd" d="M88.2071 5.27926C88.2071 3.92767 88.7455 2.79869 89.8065 1.90823C90.7092 1.14498 91.9761 0.620247 93.623 0.318126H93.6706C93.9239 0.270423 94.1615 0.238621 94.3515 0.22272C94.6207 0.190918 94.8424 0.190918 95.0166 0.190918H97.1387V22.0549C97.1387 23.8199 96.9011 25.4577 96.426 26.9365C96.1885 27.668 95.9035 28.3517 95.5551 29.0036C95.2067 29.6556 94.8108 30.2439 94.3673 30.7687C93.9556 31.2616 93.528 31.7068 93.0846 32.1202C92.6412 32.5337 92.1661 32.9153 91.6752 33.281C91.1526 33.6627 90.6142 33.9966 90.0758 34.2669C89.5057 34.5531 88.9356 34.8075 88.3338 34.9983C87.8112 35.1733 87.2886 35.3164 86.7818 35.4436C86.2909 35.5708 85.8 35.6662 85.2933 35.7457C84.3114 35.9047 83.3929 35.9842 82.5536 35.9842C82.2052 35.9842 81.8251 35.9842 81.4134 35.9365C81.0333 35.9047 80.6374 35.8729 80.2415 35.8252C79.8615 35.7775 79.4339 35.698 78.9588 35.6026C78.4996 35.5072 78.0403 35.3959 77.6127 35.2687C77.1218 35.1255 76.6467 34.9665 76.1875 34.7757C75.7282 34.5849 75.269 34.3782 74.8256 34.1556C73.9229 33.6786 73.0519 33.0743 72.2126 32.327C71.8009 31.9612 71.405 31.5478 71.0249 31.1185C70.6448 30.6733 70.2964 30.2121 70.0114 29.7669C69.7105 29.2899 69.4413 28.781 69.1879 28.2245C69.4571 27.827 69.7105 27.4294 69.9639 27.016C70.7557 25.6485 71.3575 24.2174 71.7534 22.7068C72.1493 21.1962 72.3551 19.6379 72.3551 18.0319C72.3551 16.4259 72.1493 14.8676 71.7534 13.357C71.3575 11.8464 70.7557 10.3994 69.9639 9.03191C69.378 8.03014 68.7128 7.09198 67.9844 6.23332V0.190918H70.2331C70.344 0.190918 70.4865 0.190918 70.6607 0.22272L70.9616 0.270423C71.4525 0.349929 71.4208 0.334028 71.5317 0.36583C71.7375 0.397632 72.0384 0.477137 72.4185 0.588445C72.7669 0.699752 73.0994 0.811059 73.3845 0.938268C73.5904 1.03367 73.7646 1.11318 73.9071 1.20859C74.0654 1.30399 74.2238 1.4153 74.3822 1.54251C74.588 1.68562 74.7306 1.81283 74.8097 1.89233C74.9681 2.03544 75.0948 2.16265 75.2056 2.27396C75.364 2.44887 75.5224 2.65558 75.6491 2.8782C7