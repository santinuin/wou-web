---
/**
 * Footer WOU — shell estático + isla interactiva.
 *
 * Estructura:
 *  · 4 esquinas con información fija (tagline, redes, legal, crédito)
 *  · <FooterCTA client:visible /> como isla interactiva a pantalla completa
 *    detrás de las esquinas (grid SVG distorsionado + botón GO +
 *    círculo expandible con texto RADIO / WOU! y mail).
 *
 * Arquitectura:
 *  · El shell (este archivo) permanece 100% estático. Cero JS.
 *  · Toda la animación vive en components/ui/FooterCTA.svelte, hidratada
 *    con `client:visible` — no se descarga GSAP hasta que el usuario
 *    scrollea hasta el footer.
 */
import FooterCTA from '@/components/ui/FooterCTA.svelte';

const currentYear = new Date().getFullYear();
---

<footer
  id="siteFooter"
  role="contentinfo"
  class="FooterWOU relative w-full overflow-hidden bg-brand-blue text-brand-teal"
  aria-label="Pie de página"
>
  <!-- Isla interactiva: grid animado + botón GO + círculo expandible.
       Se ubica absoluta cubriendo todo el footer (z-index 1). -->
  <FooterCTA client:visible />

  <!-- ── Esquina superior izquierda ────────────────────────────────────── -->
  <div class="FooterWOU__top-left">
    <p class="FooterWOU__tagline">
      Periodismo<br />narrativo y stream.
    </p>
    <p class="FooterWOU__location">Santa Cruz, Argentina</p>
  </div>

  <!-- ── Esquina superior derecha: redes sociales ─────────────────────── -->
  <ul class="FooterWOU__top-right" aria-label="Redes sociales">
    <li>
      <a href="https://facebook.com/" target="_blank" rel="noopener noreferrer" aria-label="Facebook de WOU">
        Facebook
      </a>
    </li>
    <li>
      <a href="https://instagram.com/" target="_blank" rel="noopener noreferrer" aria-label="Instagram de WOU">
        Instagram
      </a>
    </li>
    <li>
      <a href="https://youtube.com/" target="_blank" rel="noopener noreferrer" aria-label="YouTube de WOU">
        YouTube
      </a>
    </li>
  </ul>

  <!-- ── Esquina inferior izquierda ───────────────────────────────────── -->
  <p class="FooterWOU__bottom-left">
    © {currentYear} WOU · Todos los derechos reservados
  </p>

  <!-- ── Esquina inferior derecha ─────────────────────────────────────── -->
  <p class="FooterWOU__bottom-right">Desarrollado por Estudio Jogging</p>
</footer>

<style>
  .FooterWOU {
    --pad-x: clamp(1.25rem, 4vw, 3rem);
    --pad-y: clamp(1.25rem, 3.5vw, 2.5rem);
    min-height: 95vh;
    height: 95vh;
    max-height: 1080px;
    font-family: var(--font-franklin, 'Libre Franklin', sans-serif);
  }

  /* ── Esquinas ────────────────────────────────────────────────────── */
  .FooterWOU__top-left,
  .FooterWOU__top-right,
  .FooterWOU__bottom-left,
  .FooterWOU__bottom-right {
    position: absolute;
    z-index: 5; /* por encima de la isla FooterCTA */
    pointer-events: auto;
  }

  .FooterWOU__top-left {
    top: var(--pad-y);
    left: var(--pad-x);
  }

  .FooterWOU__tagline {
    margin: 0;
    color: var(--color-brand-teal);
    font-weight: 700;
    font-size: clamp(0.95rem, 1.15vw, 1.15rem);
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .FooterWOU__location {
    margin: clamp(2.5rem, 5vw, 4rem) 0 0;
    color: color-mix(in srgb, var(--color-brand-teal) 55%, transparent);
    font-weight: 400;
    font-size: 0.85rem;
    letter-spacing: 0.01em;
  }

  .FooterWOU__top-right {
    top: var(--pad-y);
    right: var(--pad-x);
    margin: 0;
    padding: 0;
    list-style: none;
    text-align: right;
  }
  .FooterWOU__top-right li + li { margin-top: 0.35rem; }
  .FooterWOU__top-right a {
    color: var(--color-brand-teal);
    font-weight: 700;
    font-size: clamp(0.95rem, 1.15vw, 1.15rem);
    text-decoration: none;
    transition: opacity 0.25s ease;
  }
  .FooterWOU__top-right a:hover,
  .FooterWOU__top-right a:focus-visible { opacity: 0.7; }

  .FooterWOU__bottom-left,
  .FooterWOU__bottom-right {
    bottom: var(--pad-y);
    margin: 0;
    font-size: 0.8rem;
    letter-spacing: 0.01em;
  }
  .FooterWOU__bottom-left {
    left: var(--pad-x);
    color: color-mix(in srgb, var(--color-brand-teal) 55%, transparent);
  }
  .FooterWOU__bottom-right {
    right: var(--pad-x);
    color: color-mix(in srgb, var(--color-brand-white) 40%, transparent);
  }

  /* ── Responsive: apilamos las esquinas en mobile ─────────────────── */
  @media (max-width: 640px) {
    .FooterWOU {
      min-height: 680px;
      height: auto;
      max-height: none;
      padding: 2rem 0 1.25rem;
    }
    .FooterWOU__top-left,
    .FooterWOU__top-right,
    .FooterWOU__bottom-left,
    .FooterWOU__bottom-right {
      position: static;
      display: block;
      text-align: center;
    }
    .FooterWOU__top-left { padding: 0 var(--pad-x) 0.75rem; }
    .FooterWOU__location { margin-top: 0.5rem; }
    .FooterWOU__top-right {
      padding: 0.5rem var(--pad-x) 1rem;
      text-align: center;
    }
    .FooterWOU__top-right li { display: inline-block; }
    .FooterWOU__top-right li + li { margin: 0 0 0 1rem; }
    .FooterWOU__bottom-left,
    .FooterWOU__bottom-right {
      padding: 0 var(--pad-x);
      margin-top: 0.5rem;
    }
  }
</style>
