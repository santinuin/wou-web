---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = 'Portal de contenido editorial',
  ogImage,
  canonicalUrl = Astro.url.href,
} = Astro.props;

const SITE_NAME = 'Portal de Noticias';
const fullTitle = title === SITE_NAME ? title : `${title} | ${SITE_NAME}`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <title>{fullTitle}</title>
    <meta name="generator" content={Astro.generator} />

    <!-- Fuentes del sistema de diseño -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Boldonse&family=Bowlby+One&family=Barlow:wght@700;900&family=Alumni+Sans:ital,wght@0,400;0,700;0,900;1,400&family=Libre+Franklin:wght@400;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen bg-white text-gray-900 antialiased">
    <script>
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
      window.scrollTo(0, 0);
    </script>
    <script>
      // ── Touch-hover global ────────────────────────────────────────────────
      // Simula :hover en pantallas táctiles: un toque sostenido (~200 ms sin
      // moverse) agrega `data-touch-hover` al elemento interactivo más cercano.
      // Los componentes con efectos hover usan :is(:hover, [data-touch-hover])
      // para responder a ambos estados.
      // También previene el menú contextual del SO en toda la página touch.
      (function () {
        if (!('ontouchstart' in window)) return; // solo dispositivos táctiles
        document.documentElement.classList.add('touch-device');

        const HOLD_MS       = 200;  // ms antes de activar el hover visual
        const MOVE_CANCEL   = 10;   // px de movimiento que cancela el hold

        // Selectores de los elementos que tienen efectos hover relevantes.
        // BallPool maneja su propio estado; se excluye aquí.
        const CANDIDATES = [
          'a', 'button',
          '.SupportCard', '.WideSupportCard', '.HeroCard',
          '.ReelCard', '.LineupSection__cta',
          '.FooterWOU__cta', '.FooterWOU__top-right a',
        ].join(', ');

        let hoverEl  = null;
        let holdTimer = null;
        let sx = 0, sy = 0;

        function clearHover() {
          clearTimeout(holdTimer);
          holdTimer = null;
          if (hoverEl) {
            hoverEl.removeAttribute('data-touch-hover');
            hoverEl = null;
          }
        }

        document.addEventListener('touchstart', function (e) {
          clearHover();
          const touch = e.touches[0];
          if (!touch) return;
          sx = touch.clientX;
          sy = touch.clientY;

          const target = e.target instanceof Element ? e.target : null;
          if (!target) return;

          // Ignorar el BallPool: tiene su propia lógica
          if (target.closest('.BallPool')) return;

          const candidate = target.closest(CANDIDATES);
          if (!candidate) return;

          holdTimer = setTimeout(function () {
            hoverEl = candidate;
            candidate.setAttribute('data-touch-hover', '');
          }, HOLD_MS);
        }, { passive: true });

        document.addEventListener('touchmove', function (e) {
          if (!holdTimer && !hoverEl) return;
          const t = e.touches[0];
          if (!t) return;
          if (Math.hypot(t.clientX - sx, t.clientY - sy) > MOVE_CANCEL) {
            clearHover();
          }
        }, { passive: true });

        document.addEventListener('touchend',    clearHover, { passive: true });
        document.addEventListener('touchcancel', clearHover, { passive: true });

        // Previene el menú contextual del SO en toda la página touch
        document.addEventListener('contextmenu', function (e) {
          e.preventDefault();
        });
      })();
    </script>
    <slot name="header" />
    <main id="main-content">
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>
