---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import LineupWaves from '@/components/ui/LineupWaves.svelte';
import { MOCK_SHOWS, type ShowItem } from './mocks/lineupMock';
import cambalache  from '@/assets/programs/cambalache.png';
import elRefugio   from '@/assets/programs/el-refugio.png';
import vamosviendo from '@/assets/programs/vamos-viendo.png';
import pintoVermut from '@/assets/programs/pinto-vermut.png';

const LOGOS: Record<string, ImageMetadata> = {
  'mock-cambalache':   cambalache,
  'mock-el-refugio':  elRefugio,
  'mock-vamos-viento': vamosviendo,
  'mock-pinto-vermut': pintoVermut,
};

const entries = await getCollection('radioShows');

const shows: ShowItem[] = entries.length
  ? entries.map((e) => ({
      id:   e.id,
      name: (e.data as { name: string }).name,
      days: (e.data as { days?: string | null }).days ?? null,
      time: (e.data as { time?: string | null }).time ?? null,
    }))
  : MOCK_SHOWS;
---

<!--
  Sticky scroll pattern:
  – .LineupSection tiene height dinámica (100dvh + colTravel), seteada por el script.
  – .LineupSection__sticky es el viewport visible (position: sticky, 100dvh).
  – .LineupSection__column se traslada hacia arriba a medida que el usuario scrollea,
    usando --col-ty calculado en el script de scroll.
-->
<section class="LineupSection" aria-label="Programación de radio WOU">

  <div class="LineupSection__sticky">

    <!-- Fondo animado (isla — client:only evita SSR con window) -->
    <LineupWaves client:only="svelte" />

    <!-- Grilla de programas — se mueve con scroll via --col-ty -->
    <div class="LineupSection__column" data-col>

      <!-- Títulos sobre la primera card -->
      <div class="LineupSection__header" aria-hidden="true">
        <span class="LineupSection__header-programas">Programas</span>
        <div class="LineupSection__header-freq">95.1 FM</div>
      </div>

      {shows.map((show, i) => {
        const logo = LOGOS[show.id] ?? null;
        return (
          <div
            class="LineupSection__card"
            data-card
            data-theme={i % 2 === 0 ? 'white' : 'blue'}
          >
            <div class="LineupSection__card-meta">
              <span>{show.days ?? ''}</span>
              <span>{show.time ?? ''}</span>
            </div>
            {logo ? (
              <Image
                src={logo}
                alt={show.name}
                class="LineupSection__card-logo"
                loading="lazy"
                decoding="async"
              />
            ) : (
              <h3 class="LineupSection__card-title">{show.name}</h3>
            )}
          </div>
        );
      })}

    </div>

  </div>
</section>

<style>
  /* ── Sección (altura dinámica, default 100dvh antes del script) ──────────── */
  .LineupSection {
    position: relative;
    height: var(--lineup-h, 100dvh);
    background: var(--color-brand-blue);
  }

  /* ── Sticky viewport ─────────────────────────────────────────────────────── */
  .LineupSection__sticky {
    position: sticky;
    top: 0;
    height: 100dvh;
    min-height: 560px;
    overflow: hidden;
    isolation: isolate;
  }

  /* ── Títulos (dentro de la columna, sobre la primera card) ──────────────── */
  .LineupSection__header {
    display: flex;
    flex-direction: row;
    align-items: flex-end;
    justify-content: space-between;
    pointer-events: none;
    /* sangra hacia abajo solapando el cap */
    margin-bottom: -0.7em;
  }

  /* "PROGRAMAS" — pequeño, verde, boldonse, izquierda, alineado al baseline del freq */
  .LineupSection__header-programas {
    font-family: var(--font-boldonse), sans-serif;
    font-size: clamp(0.65rem, 1.1vw, 0.85rem);
    color: var(--color-brand-white);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    line-height: 1;
    /* baja un poco para alinearse visualmente con la base del 95.1 FM */
    padding-bottom: 0.7em;
    flex-shrink: 0;
  }

  /* "95.1 FM" — grande, azul, derecha */
  .LineupSection__header-freq {
    font-family: var(--font-franklin), sans-serif;
    font-weight: 900;
    font-size: clamp(2.2rem, 6vw, 4rem);
    color: var(--color-brand-white);
    text-align: right;
    line-height: 1;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  /* ── Columna de programas ────────────────────────────────────────────────── */
  .LineupSection__column {
    position: absolute;
    top: var(--col-top, 8rem);
    left: 50%;
    z-index: 1;
    width: min(34%, 420px);
    padding-top: 0;
    padding-bottom: 0;
    /* El script setea --col-ty a medida que scrollea */
    transform: translateX(-50%) translateY(var(--col-ty, 0px));
    will-change: transform;
  }

  @media (max-width: 768px) {
    .LineupSection__column { width: min(65%, 340px); }
  }
  @media (max-width: 480px) {
    .LineupSection__column { width: 80%; }
  }

  /* ── Cards ───────────────────────────────────────────────────────────────── */
  .LineupSection__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 0.75rem 0.75rem;
    min-height: clamp(10rem, 24vh, 14rem);
  }

  .LineupSection__card[data-theme='white'] {
    background: var(--color-brand-white);
    color: var(--color-brand-blue);
  }

  .LineupSection__card[data-theme='blue'] {
    background: var(--color-brand-blue);
    color: var(--color-brand-white);
  }

  /* ── Logo del programa ───────────────────────────────────────────────────── */
  .LineupSection__card-logo {
    display: block;
    width: 80%;
    max-height: 9rem;
    object-fit: contain;
    margin: auto;
  }

  /* ── Título fallback (sin logo) ──────────────────────────────────────────── */
  .LineupSection__card-title {
    margin: 0;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-family: var(--font-alumni), sans-serif;
    font-weight: 800;
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 0.9;
    letter-spacing: -0.01em;
  }

  /* ── Meta (días + hora) ──────────────────────────────────────────────────── */
  .LineupSection__card-meta {
    display: flex;
    justify-content: space-between;
    align-self: stretch;
    font-family: var(--font-franklin), sans-serif;
    font-size: clamp(0.72rem, 1.3vw, 0.88rem);
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1.2;
  }

</style>

<script>
  (() => {
    const section = document.querySelector<HTMLElement>('.LineupSection');
    const col     = section?.querySelector<HTMLElement>('[data-col]');
    if (!section || !col) return;

    let colTravel = 0;

    function init() {
      const vpH  = window.innerHeight;
      const colH = col!.offsetHeight;
      const extraPad = 180; // espacio extra simétrico arriba y abajo
      colTravel  = colH * 0.8 + extraPad * 2;
      // Espacio arriba al inicio = espacio abajo al final del scroll
      const topOffset = Math.max(48, (vpH - colH + colTravel) / 2);
      section!.style.setProperty('--col-top', `${topOffset}px`);
      section!.style.setProperty('--lineup-h', `${vpH + colTravel}px`);
    }

    function onScroll() {
      if (colTravel <= 0) return;
      const scrolled = Math.max(0, -section!.getBoundingClientRect().top);
      section!.style.setProperty('--col-ty', `${-Math.min(scrolled, colTravel)}px`);
    }

    init();
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => { init(); onScroll(); });
  })();
</script>
