---
/**
 * RedCircle — sección full-viewport con piscina de bolas físicas (Matter.js).
 *
 * Se ubica inmediatamente debajo del Hero en la home. Ocupa el 100% del
 * viewport (100vh / 100dvh).
 *
 * Arquitectura:
 *  1. Astro (build-time) fetcha las últimas 8 entradas de la categoría
 *     "Circulo Rojo" de WordPress vía fetchWpPostsByCategory().
 *  2. El <ul> contenedor es renderizado por la isla Svelte BallPool,
 *     que se hidrata con client:visible (zero JS hasta que es visible).
 *  3. La isla aplica Matter.js sobre los <li> y sincroniza posición /
 *     rotación al DOM cada frame.
 *
 * Las imágenes se revelan en hover con una transición CSS — sin JS.
 */
import { Image } from 'astro:assets';
import BallPool from '@/components/ui/BallPool.svelte';
import { fetchSanityPostsByCategory } from '@/lib/cms';
import { getPlaceholder } from '@/lib/placeholders';
import { MOCK_RED_CIRCLES } from './mocks/redCircleMock';

type BallData = {
  id: string;
  label: string;
  href: string;
  imageUrl: string | null;
  imageAlt: string;
};

const posts = await fetchSanityPostsByCategory('circulo-rojo', 0, 8);

const balls: BallData[] = posts.length
  ? posts.map((p) => ({
      id: p.id,
      label: p.data.title,
      href: `/articulo/${p.data.slug.current}`,
      imageUrl: p.data.mainImage?.url ?? null,
      imageAlt: p.data.mainImage?.alt || p.data.title,
    }))
  : MOCK_RED_CIRCLES.map((m) => ({ ...m, imageUrl: m.imageUrl as string | null }));
---

<section
  aria-label="Círculo Rojo"
  class="RedCircleSection relative overflow-hidden bg-brand-dark"
>
  <BallPool client:visible floorSelector="#rc-floor">
    {
      balls.map((ball) => (
        <li class="BallPool--ball" data-id={ball.id}>
          <a
            class="BallPool--category"
            href={ball.href}
            aria-label={ball.label}
            draggable="false"
          >
            <span class="BallPool--category--body">
              <span class="BallPool--label">{ball.label}</span>
              <span class="BallPool--image">
                {ball.imageUrl
                  ? <img src={ball.imageUrl} alt={ball.imageAlt} width={600} height={600} loading="lazy" draggable={false} />
                  : <Image src={getPlaceholder('Circulo Rojo')} alt={ball.imageAlt} width={600} height={600} loading="lazy" />
                }
              </span>
            </span>
          </a>
        </li>
      ))
    }
  </BallPool>

  <!-- Título estático abajo: actúa como suelo visual para las bolas.
       El id="rc-floor" lo usa BallPool para posicionar el cuerpo físico. -->
  <h2
    id="rc-floor"
    class="RedCircleTitle pointer-events-none select-none"
    aria-hidden="false"
  >
    Círculo Rojo
  </h2>
</section>

<style>
  .RedCircleSection {
    height: 100vh;
    height: 100dvh;
    min-height: 520px;
    --ball-size: 18vw;
    --ball-color: #e04a3f;
    --ball-text-color: #ffffff;
  }

  @media (max-width: 1024px) {
    .RedCircleSection {
      height: 65vh;
      min-height: 400px;
      --ball-size: 26vw;
    }
  }

  @media (max-width: 640px) {
    .RedCircleSection {
      height: 55vh;
      min-height: 320px;
      --ball-size: 28vw;
    }
  }

  /* Título inferior — piso visual y físico de las bolas */
  .RedCircleTitle {
    font-family: var(--font-boldonse, 'Boldonse', sans-serif);
    font-weight: 400;
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    margin: 0;
    padding: 0;
    color: var(--ball-color);
    font-size: clamp(2.5rem, 10vw, 13rem);
    line-height: 0.85;
    text-transform: uppercase;
    white-space: nowrap;
    letter-spacing: -0.01em;
    border-bottom: 8px solid var(--ball-color);
    z-index: 1;
  }

  /* Las bolas se renderizan sobre el título */
  :global(.BallPool) {
    z-index: 2;
  }

  .BallPool--ball {
    position: absolute;
    top: 0;
    left: 0;
    width: var(--ball-individual-size, var(--ball-size));
    height: var(--ball-individual-size, var(--ball-size));
    margin-top: calc(var(--ball-individual-size, var(--ball-size)) * -0.5);
    margin-left: calc(var(--ball-individual-size, var(--ball-size)) * -0.5);
    user-select: none;
    will-change: transform;
  }

  .BallPool--category {
    display: block;
    width: 100%;
    height: 100%;
    background-color: var(--ball-color);
    border-radius: 50%;
    color: var(--ball-text-color);
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition: transform 0.25s ease;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  }

  .BallPool--category::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #ffffff;
    border-radius: inherit;
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  @media (hover: hover) and (pointer: fine) {
    .BallPool--category:hover,
    .BallPool--category:focus-visible {
      transform: rotate(-4deg) scale(1.02);
    }
    .BallPool--category:hover::before,
    .BallPool--category:focus-visible::before {
      opacity: 1;
      transform: none;
    }
    .BallPool--category:hover .BallPool--image,
    .BallPool--category:focus-visible .BallPool--image {
      opacity: 1;
    }
    .BallPool--category:hover .BallPool--label,
    .BallPool--category:focus-visible .BallPool--label {
      opacity: 0;
    }
  }

  /* Hover visual en touch (long-press) — espejo del :hover de desktop */
  .BallPool--ball.is-touch-hover .BallPool--category {
    transform: rotate(-4deg) scale(1.02);
  }
  .BallPool--ball.is-touch-hover .BallPool--category::before {
    opacity: 1;
    transform: none;
  }
  .BallPool--ball.is-touch-hover .BallPool--image {
    opacity: 1;
  }
  .BallPool--ball.is-touch-hover .BallPool--label {
    opacity: 0;
  }

  .BallPool--category--body {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12%;
    text-align: center;
    pointer-events: none;
  }

  .BallPool--label {
    font-family: var(--font-boldonse, 'Boldonse', sans-serif);
    font-weight: 400;
    text-transform: uppercase;
    line-height: 1.25;
    /* Escala proporcional al tamaño de la pelota — evita overflow en bolas chicas */
    font-size: calc(var(--ball-individual-size, var(--ball-size)) * 0.09);
    color: var(--ball-text-color);
    transform: rotate(-6deg);
    transition: opacity 0.25s ease;
    z-index: 1;
    word-break: break-word;
    hyphens: none;
  }

  .BallPool--image {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.35s ease;
    z-index: 2;
    border-radius: inherit;
    overflow: hidden;
  }

  .BallPool--image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: inherit;
    user-select: none;
    -webkit-user-drag: none;
  }
</style>
