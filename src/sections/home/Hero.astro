---
/**
 * Hero — primera sección debajo del header.
 *
 * Layout desktop (grid 50/50):
 *   Columna izquierda │ Columna derecha
 *   ─────────────────────────────────────
 *   [LiveCard][YouTube] │
 *   [── Ticker ──────] │ EditorialCard
 *   [── NewsList ────] │
 *
 * Datos: mock hasta que el CMS esté configurado en Sanity.
 * TODO: reemplazar MOCK_* por getCollection() / getEntry() de astro:content.
 */
import LiveCard from '@/components/content/LiveCard.astro';
import YoutubeEmbed from '@/components/content/YoutubeEmbed.astro';
import NewsTicker from '@/components/content/NewsTicker.astro';
import NewsList from '@/components/content/NewsList.astro';
import EditorialCard from '@/components/content/EditorialCard.astro';

// ── Mock data ──────────────────────────────────────────────────────────────
// Reemplazar por queries GROQ via getCollection() cuando el CMS esté listo.

const MOCK_RADIO = {
  isLive: true,
  station: 'WOU 95.1',
  description:
    'La 100 es la radio más escuchada del país y en Río Gallegos se escucha a través de Wou radio, en la 95.1',
  streamUrl: null,           // TODO: URL real del stream HLS/Icecast
  youtubeStreamId: null,     // TODO: ID real del stream de YouTube
};

const now = new Date();
// imageUrl vendrá del CMS: urlForImage(article.mainImage).width(200).height(140).url()
const LOREM = 'Lorem Ipsum is simply dummy text of the printing and typesetting industry.';
const MOCK_NEWS = [
  { title: 'Sube el gas', publishedAt: new Date(now.getTime() - 12 * 60_000).toISOString(), slug: 'sube-el-gas', excerpt: LOREM },
  { title: 'Fallo por YPF', publishedAt: new Date(now.getTime() - 34 * 60_000).toISOString(), slug: 'fallo-por-ypf', excerpt: LOREM },
  { title: 'El discurso no cierra', publishedAt: new Date(now.getTime() - 60 * 60_000).toISOString(), slug: 'el-discurso-no-cierra', excerpt: LOREM },
  { title: 'City tour de pascuas', publishedAt: new Date(now.getTime() - 3 * 60 * 60_000).toISOString(), slug: 'city-tour-de-pascuas', excerpt: LOREM },
];

const MOCK_TICKER = [
  'Sube el gas',
  'Fallo por YPF',
  'El discurso no cierra',
  'Paritaria en modo ahorro',
  'Mi barrio festeja llega al desfile',
];

const MOCK_EDITORIAL = {
  title: 'Sueldos de pobreza',
  question: '¿Tiene sentido resignar recursos concretos a cambio de desfinanciar salarios, salud y educación?',
  imageUrl: null,   // TODO: urlForImage(editorial.image) cuando el CMS esté listo
  imageAlt: 'Foto editorial semanal',
  slug: 'sueldos-de-pobreza',
};
---

<!--
  h-[calc(100vh-3.5rem)]: ocupa exactamente el viewport restante tras el header (h-14 = 3.5rem).
  La división al 50% coincide con el centro del logo W•U! en el header.

  Grilla 2 columnas × 3 filas:
    Fila 1 (1fr):  LiveCard+YT      │ Editorial: badge+bajada+imagen
    Fila 2 (auto): Ticker           │ Editorial: (vacía → fondo teal)
    Fila 3 (1fr):  NewsList         │ Editorial: título gigante

  El EditorialCard usa `grid-rows-subgrid` con row-span-3 para heredar
  estas filas → su contenido queda perfectamente alineado horizontalmente
  con la columna izquierda (piso de imagen = piso de LiveCard/YT).
-->
<section
  aria-label="Hero — noticias y editorial"
  class="grid grid-cols-2 grid-rows-[1fr_auto_2fr] h-[calc(100vh-5.5rem)]"
>

  <!-- ── Col izq, fila 1: LiveCard + YouTube ───────────────────────────── -->
  <div class="col-start-1 row-start-1 grid grid-cols-[2fr_3fr] bg-brand-black min-h-0 h-80 pb-5">
    <LiveCard
      isLive={MOCK_RADIO.isLive}
      station={MOCK_RADIO.station}
      description={MOCK_RADIO.description}
      streamUrl={MOCK_RADIO.streamUrl}
    />
    <YoutubeEmbed
      videoId={MOCK_RADIO.youtubeStreamId}
      station={MOCK_RADIO.station}
    />
  </div>

  <!-- ── Col izq, fila 2: Ticker ───────────────────────────────────────── -->
  <div class="col-start-1 row-start-2">
    <NewsTicker items={MOCK_TICKER} />
  </div>

  <!-- ── Col izq, fila 3: Lista de noticias ─────────────────────────────── -->
  <div class="col-start-1 row-start-3 min-h-0">
    <NewsList articles={MOCK_NEWS} buildDate={now} />
  </div>

  <!-- ── Col der, filas 1-3: Editorial Semanal (subgrid) ────────────────── -->
  <EditorialCard
    title={MOCK_EDITORIAL.title}
    question={MOCK_EDITORIAL.question}
    imageUrl={MOCK_EDITORIAL.imageUrl}
    imageAlt={MOCK_EDITORIAL.imageAlt}
    slug={MOCK_EDITORIAL.slug}
  />

</section>
