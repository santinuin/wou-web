---
/**
 * Hero — primera sección debajo del header.
 *
 * Layout desktop (grid 50/50):
 *   Columna izquierda │ Columna derecha
 *   ─────────────────────────────────────
 *   [LiveCard][YouTube] │
 *   [── Ticker ──────] │ EditorialCard
 *   [── NewsList ────] │
 */
import { getCollection } from 'astro:content';
import LiveCard from '@/components/content/LiveCard.astro';
import YoutubeStream from '@/components/ui/YoutubeStream.svelte';
import NewsTicker from '@/components/content/NewsTicker.astro';
import NewsList from '@/components/content/NewsList.astro';
import EditorialCard from '@/components/content/EditorialCard.astro';
import editorialImageMock from '@/assets/editorial-image-mock.png';
import youtubePlaceholder from '@/assets/placeholders/youtube.png';

const now = new Date();

// Artículos recientes excluyendo "Círculo Rojo" — ya están en el collection (build-time)
const rawArticles = await getCollection('articles');
const newsItems = rawArticles
  .filter((a) => !a.data.categories?.some((c) => c.title === 'Circulo Rojo' || c.title === 'Círculo Rojo'))
  .sort((a, b) => (b.data.publishedAt ?? '').localeCompare(a.data.publishedAt ?? ''))
  .slice(0, 4)
  .map((a) => ({
    title: a.data.title,
    publishedAt: a.data.publishedAt ?? now.toISOString(),
    slug: a.data.slug.current,
    href: `/articulo/${a.data.slug.current}`,
    imageUrl: a.data.mainImage?.url ?? null,
    excerpt: a.data.excerpt ?? null,
  }));

const tickerItems = newsItems.map((a) => a.title);

const MOCK_EDITORIAL = {
  title: 'Sueldos de pobreza',
  highlightWord: 'pobreza',
  imageUrl: editorialImageMock.src,
  imageAlt: 'Foto editorial semanal',
  slug: 'sueldos-de-pobreza',
};

---

<!--
  h-[calc(100vh-3.5rem)]: ocupa exactamente el viewport restante tras el header (h-14 = 3.5rem).
  La división al 50% coincide con el centro del logo W•U! en el header.

  Grilla 2 columnas × 3 filas:
    Fila 1 (1fr):  LiveCard+YT      │ Editorial: badge+bajada+imagen
    Fila 2 (auto): Ticker           │ Editorial: (vacía → fondo teal)
    Fila 3 (1fr):  NewsList         │ Editorial: título gigante

  El EditorialCard usa `grid-rows-subgrid` con row-span-3 para heredar
  estas filas → su contenido queda perfectamente alineado horizontalmente
  con la columna izquierda (piso de imagen = piso de LiveCard/YT).
-->
<section
  aria-label="Hero — noticias y editorial"
  class="flex flex-col lg:grid lg:grid-cols-2 lg:h-[calc(100vh-5.5rem)]"
>

  <!-- Ticker mobile/tablet: primer elemento debajo del header (en desktop vive en la col derecha) -->
  <div class="order-1 lg:hidden">
    <NewsTicker items={tickerItems} />
  </div>

  <!-- ── Columna izquierda ──────────────────────────────────────────────── -->
  <!--
    En mobile/tablet la columna usa `display: contents` para que sus hijos
    (LiveCard+YT y NewsList) fluyan directamente al flex de la section y
    se puedan ordenar individualmente con `order-*`. En desktop vuelve a
    ser un flex-col que ocupa la columna 1 del grid.
  -->
  <div class="contents lg:flex lg:flex-col lg:bg-brand-dark lg:min-h-0">

    <!--
      LiveCard + YouTube
      Desktop: grid lado a lado (col 1, arriba).
      Mobile/tablet: el wrapper usa `contents` para que YT y LiveCard fluyan
      como items individuales del flex de la section. YT va primero (order-4)
      y LiveCard al final (order-5).
    -->
    <div class="contents lg:grid lg:order-1 lg:grid-cols-[2fr_4fr] lg:shrink-0 lg:h-[42%] lg:bg-brand-dark">
      <!-- LiveCard — desktop: col izq; mobile/tablet: último, con más alto para que las waves respiren -->
      <div class="order-5 lg:order-1 h-72 lg:h-auto bg-brand-dark">
        <LiveCard isLive={true} streamUrl={null} />
      </div>
      <!-- YoutubeStream — desktop: col der; mobile/tablet: después del editorial -->
      <div class="order-4 lg:order-2 h-52 lg:h-auto bg-brand-black">
        <YoutubeStream station="Cambalache" placeholder={youtubePlaceholder.src} client:load />
      </div>
    </div>

    <!-- Lista de noticias — mobile/tablet: justo después del ticker; desktop: debajo de LiveCard -->
    <div class="order-2 lg:order-2 min-h-64 lg:flex-1 lg:min-h-0">
      <NewsList articles={newsItems} buildDate={now} />
    </div>

  </div>

  <!-- ── Columna derecha: ticker + editorial ───────────────────────────── -->
  <!-- Mobile/tablet: va tercero (entre NewsList y LiveCard), con padding alrededor
       para que se vea el dark del fondo como margen. Desktop: col 2 del grid, sin padding. -->
  <div class="order-3 lg:order-2 flex flex-col lg:min-h-0 min-h-[60svh] px-4 py-4 bg-brand-dark lg:px-0 lg:py-0 lg:bg-transparent">

    <!-- Ticker al tope de la columna (solo desktop — en mobile vive arriba del section) -->
    <div class="hidden lg:block">
      <NewsTicker items={tickerItems} />
    </div>

    <!-- Editorial -->
    <EditorialCard
      title={MOCK_EDITORIAL.title}
      highlightWord={MOCK_EDITORIAL.highlightWord}
      imageUrl={MOCK_EDITORIAL.imageUrl}
      imageAlt={MOCK_EDITORIAL.imageAlt}
      slug={MOCK_EDITORIAL.slug}
    />

  </div>

</section>
