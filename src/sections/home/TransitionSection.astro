---
/**
 * TransitionSection — scroll-driven, sin hover.
 *
 * p = progreso de scroll normalizado [0, 1] sobre 350vh de wrapper.
 *
 * Fase 1  [0.00 → 0.42]  Pastilla azul se expande. "Abrí la ventana" desaparece.
 * Fase 2  [0.38 → 0.48]  "Esto es WOU" aparece rápido.
 * Fase 3  [0.38 → 0.92]  "Esto es WOU" hace zoom ×15 continuo; se esfuma recién en [0.78→0.92].
 * Fase 4  [0.85 → 1.00]  Fondo azul desaparece. Sticky se disuelve → NewsGrid.
 */
---

<section class="TSec" aria-label="Transición — Esto es WOU">
  <div class="TSec__sticky">
    <div class="TSec__pill"  aria-hidden="true"></div>
    <span class="TSec__label font-bowlby" aria-hidden="true">Abrí la ventana</span>
    <h2  class="TSec__headline font-bowlby" aria-hidden="true">Esto es WOU</h2>
  </div>
</section>

<p class="TSec__sr">Esto es WOU</p>

<script>
  const section  = document.querySelector<HTMLElement>('.TSec')!;
  const sticky   = section.querySelector<HTMLElement>('.TSec__sticky')!;
  const pill     = section.querySelector<HTMLElement>('.TSec__pill')!;
  const label    = section.querySelector<HTMLElement>('.TSec__label')!;
  const headline = section.querySelector<HTMLElement>('.TSec__headline')!;

  const REDUCED = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const LERP    = REDUCED ? 1 : 0.1;

  let pillScale = 1,  tPillScale = 1;
  let pillOp    = 1,  tPillOp    = 1;
  let labelOp   = 1,  tLabelOp   = 1;
  let hlOp      = 0,  tHlOp      = 0;
  let hlScale   = 1,  tHlScale   = 1;
  let stickyOp  = 1,  tStickyOp  = 1;

  function c(x: number) { return Math.max(0, Math.min(x, 1)); }
  function eio(t: number) { return t < 0.5 ? 2*t*t : -1+(4-2*t)*t; }
  function ein(t: number) { return t * t * t; }

  function onScroll() {
    const scrollable = section.offsetHeight - window.innerHeight;
    if (scrollable <= 0) return;
    const p = c((window.scrollY - section.offsetTop) / scrollable);

    // Fase 1: pastilla crece, label desaparece
    const p1      = eio(c(p / 0.42));
    tPillScale    = 1 + p1 * 39;
    tLabelOp      = c(1 - p1 * 3);

    // Fase 2: headline aparece rápido, crece continuamente hasta p=0.90
    const hlIn    = eio(c((p - 0.38) / 0.10));       // aparece rápido 0.38→0.48
    // Fase 3: desaparece recién cuando está muy grande (p=0.78→0.92)
    const hlOut   = eio(c((p - 0.78) / 0.14));       // esfumado tardío
    tHlOp         = c(hlIn * (1 - hlOut * 1.4));
    tHlScale      = 1 + ein(c((p - 0.38) / 0.52)) * 14; // zoom 1 → 15, desde que aparece

    // Fase 4: azul desaparece, sticky se disuelve
    const p4      = eio(c((p - 0.85) / 0.15));
    tPillOp       = 1 - p4;
    tStickyOp     = c(1 - p4 * 1.4);
  }

  function render() {
    pillScale = pillScale + (tPillScale - pillScale) * LERP;
    pillOp    = pillOp    + (tPillOp    - pillOp)    * LERP;
    labelOp   = labelOp   + (tLabelOp   - labelOp)   * LERP;
    hlOp      = hlOp      + (tHlOp      - hlOp)      * LERP;
    hlScale   = hlScale   + (tHlScale   - hlScale)    * LERP;
    stickyOp  = stickyOp  + (tStickyOp  - stickyOp)  * LERP;

    pill.style.transform     = `scale(${pillScale.toFixed(3)})`;
    pill.style.opacity       = pillOp.toFixed(3);
    label.style.opacity      = labelOp.toFixed(3);
    headline.style.opacity   = hlOp.toFixed(3);
    headline.style.transform = `scale(${hlScale.toFixed(3)})`;
    sticky.style.opacity     = stickyOp.toFixed(3);

    requestAnimationFrame(render);
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
  requestAnimationFrame(render);
</script>

<style>
  .TSec {
    position: relative;
    height: 350vh;
    background: var(--color-brand-dark);
    z-index: 2;
  }

  .TSec__sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-brand-black);
    isolation: isolate;
    --pill-w: 20rem;
    --pill-h: 3rem;
    will-change: opacity;
  }

  .TSec__pill {
    position: absolute;
    inset: 0;
    margin: auto;
    width: var(--pill-w);
    height: var(--pill-h);
    background: var(--color-brand-blue);
    transform-origin: center center;
    will-change: transform, opacity;
    pointer-events: none;
    z-index: 0;
  }

  .TSec__label {
    position: relative;
    z-index: 1;
    width: var(--pill-w);
    height: var(--pill-h);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-brand-green);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: clamp(1.1rem, 1.6vw, 1.6rem);
    pointer-events: none;
    will-change: opacity;
  }

  .TSec__headline {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 0 1rem;
    color: var(--color-brand-green);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    line-height: 0.95;
    text-align: center;
    font-size: clamp(2.5rem, 8vw, 6.5rem);
    opacity: 0;
    pointer-events: none;
    transform-origin: center center;
    will-change: opacity, transform;
  }

  .TSec__sr {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .TSec { height: 110vh; }
    .TSec__sticky { position: relative; }
  }
</style>
