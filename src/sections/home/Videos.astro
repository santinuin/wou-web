---
import { getCollection } from 'astro:content';
import ScrollCarousel from '@/components/ui/ScrollCarousel.svelte';
import { parseYouTubeId, getYouTubeThumbUrl, getYouTubeWatchUrl } from '@/lib/youtube';
import { MOCK_VIDEOS, type VideoItem } from './mocks/videoMock';

const MAX_VIDEOS = 8;

type RawVideo = {
  _id: string;
  title: string;
  youtubeUrl: string;
  guest?: string | null;
};

const entries = await getCollection('programs');

const videos: VideoItem[] = (
  entries.length
    ? entries
        .map((e) => {
          const d = e.data as RawVideo;
          const videoId = parseYouTubeId(d.youtubeUrl);
          if (!videoId) return null;
          return {
            id: d._id,
            title: d.title,
            guest: d.guest ?? null,
            videoId,
            thumbUrl: getYouTubeThumbUrl(videoId, 'max'),
            watchUrl: getYouTubeWatchUrl(videoId),
          } satisfies VideoItem;
        })
        .filter((x): x is VideoItem => x !== null)
    : MOCK_VIDEOS
).slice(0, MAX_VIDEOS);

/**
 * Seeds determinísticos (hash del id) para --y y --size. Mismo video →
 * misma posición decorativa en cada build.
 */
function hash(id: string, salt: number): number {
  let h = 0;
  for (let k = 0; k < id.length; k++) h = (h * salt + id.charCodeAt(k)) | 0;
  return ((h >>> 0) % 1000) / 1000;
}
function seededY(id: string, i: number): number {
  const sign = i % 2 ? -1 : 1;
  return +((0.5 + hash(id, 31) * 0.5) * sign).toFixed(3);
}
function seededSize(id: string): number {
  return +(0.5 + hash(id, 17) * 0.5).toFixed(3);
}

const total = videos.length;

function captionKey(id: string, i: number): string {
  let h = 0;
  for (let k = 0; k < id.length; k++) h = (h * 37 + id.charCodeAt(k)) | 0;
  const r = (h >>> 0).toString(36).padStart(4, '0').slice(0, 4);
  return `${r}-${String(i).padStart(4, '0')}/${String(total).padStart(2, '0')}`;
}
---

<section class="VideosSection" aria-label="Videos de WOU">
  <ScrollCarousel client:idle count={total}>
    <div class="VideosSection__outer" data-outer>
      <div class="VideosSection__inner" data-inner>
        <h2 class="VideosSection__title" aria-hidden="true">
          <span class="VideosSection__title-inner" data-title>
            <span class="VideosSection__letter" data-letter>W</span>
            <span class="VideosSection__letter" data-letter>O</span>
            <span class="VideosSection__letter" data-letter>U</span>
          </span>
        </h2>

        <div class="VideosSection__scene" data-scene>
          {
            videos.map((v, i) => (
              <article
                class="VideosSection__work"
                data-video
                style={`--size: ${seededSize(v.id)}; --y: ${seededY(v.id, i)}; --progress: 1`}
              >
                <div class="VideosSection__work-inner">
                  <a
                    href={v.watchUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Ver "${v.title}" en YouTube${v.guest ? ` — ${v.guest}` : ''}`}
                  >
                    <div class="VideosSection__thumb">
                      <img
                        src={v.thumbUrl}
                        alt={v.title}
                        width={1280}
                        height={720}
                        loading="lazy"
                        decoding="async"
                        draggable="false"
                      />
                    </div>
                    <div class="VideosSection__caption">
                      <div class="VideosSection__caption-text">
                        {v.title}
                        {v.guest && <span class="VideosSection__caption-guest">— {v.guest}</span>}
                      </div>
                      <div class="VideosSection__caption-key">#{captionKey(v.id, i)}</div>
                    </div>
                  </a>
                </div>
              </article>
            ))
          }
        </div>

        <canvas class="VideosSection__canvas" data-canvas></canvas>
      </div>

      <div class="VideosSection__mask-outer">
        <div class="VideosSection__mask" data-mask>
          <svg class="VideosSection__mask-svg" data-mask-svg>
            <path class="VideosSection__mask-path-inner" data-mask-inner></path>
            <path class="VideosSection__mask-path-outer" data-mask-outer></path>
            <path class="VideosSection__mask-path-lines" data-mask-lines></path>
          </svg>
        </div>
      </div>

      <div class="VideosSection__ruler" data-ruler aria-hidden="true"></div>
    </div>
  </ScrollCarousel>

  <!-- Franjas oscuras que cruzan los límites con las secciones vecinas
       (Lineup arriba, Footer abajo). position:absolute con top/bottom
       negativo → quedan a caballo del borde entre secciones; z-index alto
       → pintan por encima del contenido verde. Tapan la mella sub-píxel
       del límite entre secciones apiladas. -->
  <div class="VideosSection__seam VideosSection__seam--top" aria-hidden="true"></div>
  <div class="VideosSection__seam VideosSection__seam--bottom" aria-hidden="true"></div>
</section>

<style>
  .VideosSection {
    /* --height lo setea la isla: videos.length * 50lvh */
    --height: 100lvh;
    position: relative;
    z-index: 2;
    height: var(--height);
    margin-bottom: -1px;
    background: var(--color-brand-blue);
    color: var(--color-brand-green);
    isolation: isolate;
  }

  /* ── Mask píldora (sticky en el viewport) ──────────────────────────── */
  .VideosSection__mask-outer {
    position: sticky;
    top: 0;
    left: 0;
    z-index: 3;
    width: 100%;
    height: 100lvh;
    overflow: hidden;
    pointer-events: none;
  }
  .VideosSection__mask {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    will-change: scale, transform;
  }
  .VideosSection__mask-svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  .VideosSection__mask-path-outer {
    fill: var(--color-brand-blue);
    fill-rule: evenodd;
  }
  .VideosSection__mask-path-inner {
    display: none;
  }
  .VideosSection__mask-path-lines {
    display: none;
  }

  /* Franjas que cruzan los límites con las secciones vecinas — tapan la
     mella sub-píxel del borde entre secciones apiladas. z-index alto para
     pintar por encima del contenido (incluida la máscara y las letras). */
  .VideosSection__seam {
    position: absolute;
    left: 0;
    right: 0;
    height: 16px;
    background: var(--color-brand-dark);
    z-index: 10;
    pointer-events: none;
  }
  .VideosSection__seam--top {
    top: -8px;
  }
  .VideosSection__seam--bottom {
    bottom: -8px;
  }

  /* ── Outer / Inner ─────────────────────────────────────────────────── */
  .VideosSection__outer {
    position: relative;
    height: var(--height);
    clip-path: inset(0 -1rem);
  }
  /* Fixed (no sticky): el outer tiene clip-path y height:var(--height),
     eso clipea el inner a la rect del outer. Cuando el outer sale del
     viewport, el inner queda clippeado → invisible. */
  .VideosSection__inner {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100lvh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--color-brand-dark);
    color: var(--color-brand-green);
    transform: translate3d(0, calc(var(--scroll-progress, 0) * -15%), 0);
    will-change: clip-path, transform, scale;
    clip-path: inset(0 1rem);
  }
  @media (max-width: 576px) {
    .VideosSection__inner {
      transform: none;
    }
  }

  /* ── Ruler ─────────────────────────────────────────────────────────── */
  .VideosSection__ruler {
    --w: min(16.6667%, 19.625rem);
    position: absolute;
    top: 10lvh;
    left: calc(50% - var(--w) / 2);
    width: var(--w);
    height: 80lvh;
    pointer-events: none;
    visibility: hidden;
  }
  @media (max-width: 987px) {
    .VideosSection__ruler {
      --w: 33.3333%;
    }
  }
  @media (max-width: 576px) {
    .VideosSection__ruler {
      --w: 50%;
    }
  }

  /* ── Título (ref invisible) + ghosts ───────────────────────────────── */
  .VideosSection__title,
  .VideosSection__scene {
    font-family: var(--font-boldonse), sans-serif;
    font-weight: 900;
    font-size: min(18rem, 20lvh);
    line-height: 1;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }
  @media (max-width: 987px) {
    .VideosSection__title,
    .VideosSection__scene {
      font-size: min(18rem, 22lvh);
    }
  }
  @media (max-width: 576px) {
    .VideosSection__title,
    .VideosSection__scene {
      font-size: min(28vw, 14rem);
    }
  }
  .VideosSection__title-inner,
  .VideosSection__scene :global(.VideosSection__ghost) {
    line-height: 1.5;
  }
  .VideosSection__title {
    width: 0.7em;
    opacity: 0;
    word-break: break-all;
    margin: 0;
  }
  .VideosSection__title-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin: 0.075em 0 -0.125em;
  }

  /* ── Escena ────────────────────────────────────────────────────────── */
  .VideosSection__scene {
    --state: 0;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 2;
    width: 100%;
    height: 100%;
    perspective: 40rem;
    will-change: transform, scale;
  }

  /* Ghost letter (inyectada por la isla). --progress lo cicla JS. */
  .VideosSection__scene :global(.VideosSection__ghost) {
    --head: calc((var(--progress, 0.5) - 0.5) * -2);
    --ahead: calc(var(--head) * var(--head));
    position: absolute;
    top: 0;
    left: 0;
    display: block;
    color: color-mix(in srgb, var(--color-brand-blue-light) calc(var(--state, 0) * 100%), var(--color-brand-green));
    transform: rotateY(calc(var(--head) * -10deg * var(--state)))
      translate3d(
        calc(var(--head) * 50vw * var(--state)),
        calc(var(--iy, 0) * 50% * var(--ahead) * var(--state)),
        0
      );
    pointer-events: none;
    will-change: transform;
  }
  .VideosSection__scene :global(.VideosSection__ghost::before) {
    display: none;
  }

  /* ── Work ──────────────────────────────────────────────────────────── */
  .VideosSection__work {
    position: absolute;
    top: 50%;
    left: 50%;
    z-index: 2;
    margin: 0;
    padding: 0.5rem 0.5rem 0;
    background: var(--color-brand-dark);
    content-visibility: hidden;
    transform-style: preserve-3d;
    will-change: transform;
    transform: rotateY(calc(var(--progress, 1) * -20deg))
      translate3d(
        calc(var(--progress, 1) * (50vw + 100%) - 50%),
        calc(var(--y, 0) * 50% - 50%),
        calc(var(--progress, 1) * var(--progress, 1) * -5rem)
      )
      scale(var(--size, 1));
  }
  .VideosSection__work[data-inview] {
    content-visibility: visible;
  }
  @media (max-width: 987px) {
    .VideosSection__work {
      transform: rotateY(calc(var(--progress, 1) * -20deg))
        translate3d(
          calc(var(--progress, 1) * (50vw + 100%) - 50%),
          calc(var(--y, 0) * 50% - 50%),
          calc(var(--progress, 1) * var(--progress, 1) * -5rem)
        );
    }
  }
  @media (max-width: 576px) {
    .VideosSection__work {
      padding: 0.25rem;
      transform: rotateY(calc(var(--progress, 1) * -20deg))
        translate3d(
          calc(var(--progress, 1) * (50vw + 100%) - 50%),
          calc(var(--y, 0) * 100% - 50%),
          calc(var(--progress, 1) * var(--progress, 1) * -5rem)
        );
    }
  }
  .VideosSection__work a {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .VideosSection__work-inner {
    display: block;
    margin: 0;
    padding: 0;
  }

  .VideosSection__thumb {
    display: block;
    width: auto;
    max-width: 100vw;
    aspect-ratio: 16 / 9;
    background: var(--color-brand-dark);
    overflow: hidden;
    position: relative;
  }
  .VideosSection__thumb img {
    display: block;
    width: 100%;
    height: 100%;
    max-width: 100vw;
    max-height: 90vh;
    object-fit: cover;
    user-select: none;
    -webkit-user-drag: none;
  }
  @media (max-width: 576px) {
    .VideosSection__thumb img {
      max-width: 95vw;
      max-height: 85vh;
    }
  }
  .VideosSection__thumb::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 3rem;
    height: 3rem;
    transform: translate(-50%, -50%);
    background-color: var(--color-brand-green);
    clip-path: polygon(30% 20%, 30% 80%, 80% 50%);
    opacity: 0.9;
    pointer-events: none;
  }

  .VideosSection__caption {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.5rem;
    color: var(--color-brand-green);
    font-family: ui-monospace, 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 11px;
    line-height: 1;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-align: right;
    gap: 0.75rem;
  }
  .VideosSection__caption-text {
    text-align: left;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .VideosSection__caption-guest {
    opacity: 0.7;
    margin-left: 0.35rem;
  }
  .VideosSection__caption-key {
    flex-shrink: 0;
    opacity: 0.7;
  }
  @media (max-width: 576px) {
    .VideosSection__caption {
      display: none;
    }
  }

  /* ── Canvas (textura de puntos) — desactivado ──────────────────────── */
  .VideosSection__canvas {
    display: none;
  }
</style>
