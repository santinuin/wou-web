---
import HeroCard from '@/components/content/HeroCard.astro';
import { getImageUrl } from '@/lib/cms';
import { decodeHtmlEntities } from '@/lib/utils';
import type { ArticleLike } from '@/sections/home/mocks/newsGridMock';

interface Props {
  article: ArticleLike;
  categoryDisplay: string;
}

const { article, categoryDisplay } = Astro.props;

const imageUrl = getImageUrl(article.data.mainImage);
const categoryTitle = article.data.categories?.[0]?.title ?? categoryDisplay;
const tickerText = decodeHtmlEntities(article.data.excerpt ?? article.data.title);
---

<div class="CategoryHero">
  <HeroCard
    title={article.data.title}
    slug={article.data.slug.current}
    categoryTitle={categoryTitle}
    imageUrl={imageUrl}
    imageAlt={article.data.mainImage?.alt ?? article.data.title}
    tickerText={tickerText}
  />
</div>

<style>
  .CategoryHero {
    height: 88vh;
    max-height: 1000px;
    min-height: 620px;
    border-radius: 10px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    border: 2px solid var(--color-brand-dark);
  }

  /* Variante del hero de sección:
       · Bloque del título con fondo BLANCO y texto oscuro (vs teal en home)
       · Ticker con fondo teal (texto oscuro hereda de HeroCard)            */
  .CategoryHero :global(.HeroCard__body) {
    background: var(--color-brand-white);
  }

  .CategoryHero :global(.HeroCard__title) {
    font-size: clamp(3rem, 17cqi, 12rem);
    -webkit-line-clamp: 2;
    hyphens: none;
  }

  @media (max-width: 1024px) {
    .CategoryHero :global(.HeroCard__body)  { padding: 1rem 1.5rem; }
    .CategoryHero :global(.HeroCard__title) { font-size: clamp(4rem, 22cqi, 16rem); line-height: 0.68; -webkit-line-clamp: 3; hyphens: auto; }
  }

  @media (max-width: 640px) {
    .CategoryHero :global(.HeroCard__body)  { padding: 0.75rem 0.75rem; }
    .CategoryHero :global(.HeroCard__title) { font-size: clamp(4.5rem, 22cqi, 16rem); line-height: 0.65; -webkit-line-clamp: 3; hyphens: auto; }
  }

  .CategoryHero :global(.HeroCard__ticker) {
    background: var(--color-brand-teal);
  }

  @media (max-width: 1024px) {
    .CategoryHero {
      height: 70vh;
      min-height: 480px;
    }
  }

  @media (max-width: 640px) {
    .CategoryHero {
      height: 420px;
      min-height: unset;
    }
  }
</style>
