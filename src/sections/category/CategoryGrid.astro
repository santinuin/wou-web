---
import SupportCard from '@/components/content/SupportCard.astro';
import WideSupportCard from '@/components/content/WideSupportCard.astro';
import { getImageUrl } from '@/lib/cms';
import type { ArticleLike } from '@/sections/home/mocks/newsGridMock';
import { BAND_PATTERN, type BandRow } from './bandPattern';

interface Props {
  articles: ArticleLike[];
}

const { articles } = Astro.props;

type Row = BandRow & { items: ArticleLike[] };
const rows: Row[] = [];
let cursor = 0;
let patternIdx = 0;

while (cursor < articles.length) {
  const slot = BAND_PATTERN[patternIdx % BAND_PATTERN.length];
  const items = articles.slice(cursor, cursor + slot.cols);
  if (items.length === 0) break;
  rows.push({ ...slot, items });
  cursor += slot.cols;
  patternIdx++;
}
---

<div class="CategoryGrid">
  {rows.map(({ cols, type, items }) => (
    <div class={`CategoryGrid__row CategoryGrid__row--${type}`}>
      {items.map((article) => {
        const imageUrl = getImageUrl(article.data.mainImage as any);
        const slug = article.data.slug.current;
        const title = article.data.title;
        const categoryTitle = article.data.categories?.[0]?.title ?? null;
        const imageAlt = article.data.mainImage?.alt ?? title;

        return cols === 1
          ? (
            <WideSupportCard
              title={title}
              slug={slug}
              categoryTitle={categoryTitle}
              imageUrl={imageUrl}
              imageAlt={imageAlt}
            />
          )
          : (
            <SupportCard
              title={title}
              slug={slug}
              categoryTitle={categoryTitle}
              imageUrl={imageUrl}
              imageAlt={imageAlt}
            />
          );
      })}
    </div>
  ))}
</div>

<style is:global>
  .CategoryGrid {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .CategoryGrid__row {
    display: grid;
    gap: 8px;
  }

  /* Borde oscuro en todas las cards del grid (también para las cargadas vía LoadMore). */
  .CategoryGrid .SupportCard,
  .CategoryGrid .WideSupportCard,
  .LoadMore__rows .SupportCard,
  .LoadMore__rows .WideSupportCard {
    border: 2px solid var(--color-brand-dark);
    border-radius: 8px;
    /* min-height:0 evita que el min-content (imagen) empuje la card
       más allá del height del row. */
    min-height: 0;
    overflow: hidden;
  }

  /* Imagen como background absoluto — desacopla el aspect-ratio
     intrínseco del flex/grid sizing. */
  .CategoryGrid .SupportCard__image-zone,
  .LoadMore__rows .SupportCard__image-zone,
  .CategoryGrid .WideSupportCard__image-zone,
  .LoadMore__rows .WideSupportCard__image-zone {
    position: relative;
    min-height: 0;
    overflow: hidden;
  }

  .CategoryGrid .SupportCard__image-zone {
    border-radius: 6px 6px 0 0;
  }

  .CategoryGrid .SupportCard__image,
  .LoadMore__rows .SupportCard__image,
  .CategoryGrid .WideSupportCard__image,
  .LoadMore__rows .WideSupportCard__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .CategoryGrid .SupportCard__body,
  .LoadMore__rows .SupportCard__body,
  .CategoryGrid .WideSupportCard__body,
  .LoadMore__rows .WideSupportCard__body {
    min-height: 0;
    container-type: inline-size;
  }

  /* Tamaño de título ajustado para que entre cómodo en cards angostas.
     Override del default (clamp(2.2rem, 4vw, 4rem)) que era demasiado
     grande para 3-col y los lados angostos de bandas asimétricas.       */
  .CategoryGrid .SupportCard__title,
  .LoadMore__rows .SupportCard__title {
    font-size: clamp(2.2rem, 22cqi, 4rem);
    line-height: 0.72;
    display: -webkit-box !important;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    hyphens: auto;
    overflow-wrap: break-word;
  }

  /* Cards más anchas (lado wider de bandas asimétricas y banda C) pueden
     usar título un poco más grande. */
  .CategoryGrid__row--a > .SupportCard:nth-child(1) .SupportCard__title,
  .CategoryGrid__row--d > .SupportCard:nth-child(2) .SupportCard__title,
  .CategoryGrid__row--f > .SupportCard:nth-child(2) .SupportCard__title,
  .CategoryGrid__row--c .SupportCard__title,
  .LoadMore__rows .CategoryGrid__row--a > .SupportCard:nth-child(1) .SupportCard__title,
  .LoadMore__rows .CategoryGrid__row--d > .SupportCard:nth-child(2) .SupportCard__title,
  .LoadMore__rows .CategoryGrid__row--f > .SupportCard:nth-child(2) .SupportCard__title,
  .LoadMore__rows .CategoryGrid__row--c .SupportCard__title {
    font-size: clamp(2.6rem, 24cqi, 5rem);
  }

  /* ── Banda A: 2 cols asimétrica, izquierda más ancha ───────────── */
  .CategoryGrid__row--a {
    grid-template-columns: 1.6fr 1fr;
    height: 420px;
  }

  /* ── Banda B: 3 cols equal ─────────────────────────────────────── */
  .CategoryGrid__row--b {
    grid-template-columns: 1fr 1fr 1fr;
    height: 340px;
  }

  /* ── Banda C: 2 cols equal (más alta — featured) ───────────────── */
  .CategoryGrid__row--c {
    grid-template-columns: 1fr 1fr;
    height: 540px;
  }

  /* ── Banda D: 2 cols asimétrica, derecha más ancha (mirror A) ──── */
  .CategoryGrid__row--d {
    grid-template-columns: 1fr 1.6fr;
    height: 420px;
  }

  /* ── Banda E: 1 card a todo el ancho — layout HORIZONTAL ──────── */
  .CategoryGrid__row--e {
    grid-template-columns: 1fr;
    height: 260px;
  }

  .CategoryGrid__row--e .WideSupportCard,
  .LoadMore__rows .CategoryGrid__row--e .WideSupportCard {
    flex-direction: row;
  }

  .CategoryGrid__row--e .WideSupportCard__image-zone,
  .LoadMore__rows .CategoryGrid__row--e .WideSupportCard__image-zone {
    flex: 0 0 32%;
    border-radius: 6px 0 0 6px;
  }

  .CategoryGrid__row--e .WideSupportCard__body,
  .LoadMore__rows .CategoryGrid__row--e .WideSupportCard__body {
    flex: 1 1 auto;
    justify-content: center;
    padding: 1.5rem 2.5rem;
  }

  .CategoryGrid__row--e .WideSupportCard__category,
  .LoadMore__rows .CategoryGrid__row--e .WideSupportCard__category {
    position: relative;
    top: auto;
    left: auto;
    transform: none;
    align-self: flex-start;
    margin-bottom: 0.5rem;
  }

  .CategoryGrid__row--e .WideSupportCard__title,
  .LoadMore__rows .CategoryGrid__row--e .WideSupportCard__title {
    white-space: normal;
    font-size: clamp(2.6rem, 22cqi, 5rem);
    line-height: 0.72;
    hyphens: auto;
    overflow-wrap: break-word;
  }

  /* ── Banda F: 2 cols, derecha mucho más ancha ──────────────────── */
  .CategoryGrid__row--f {
    grid-template-columns: 1fr 2fr;
    height: 400px;
  }

  /* ── Banda G: 3 cols equal ─────────────────────────────────────── */
  .CategoryGrid__row--g {
    grid-template-columns: 1fr 1fr 1fr;
    height: 340px;
  }

  @media (max-width: 1024px) {
    .CategoryGrid__row--a { height: 320px; }
    .CategoryGrid__row--b,
    .CategoryGrid__row--g { height: 260px; }
    .CategoryGrid__row--c { height: 420px; }
    .CategoryGrid__row--d { height: 320px; }
    .CategoryGrid__row--e { height: 200px; }
    .CategoryGrid__row--f { height: 300px; }

    .CategoryGrid .SupportCard__title,
    .LoadMore__rows .SupportCard__title {
      font-size: clamp(1rem, 18cqi, 3.2rem);
      line-height: 0.68;
      hyphens: none;
    }
  }

  @media (max-width: 640px) {
    .CategoryGrid__row--a { height: 200px; }
    .CategoryGrid__row--b,
    .CategoryGrid__row--g { height: 170px; }
    .CategoryGrid__row--c { height: 280px; }
    .CategoryGrid__row--d { height: 200px; }
    .CategoryGrid__row--e { height: 160px; }
    .CategoryGrid__row--f { height: 220px; }

    /* Clamp mínimo bajo para que cqi controle en cards angostas */
    .CategoryGrid .SupportCard__title,
    .LoadMore__rows .SupportCard__title {
      font-size: clamp(1rem, 25cqi, 3.2rem);
      line-height: 0.7;
      hyphens: none;
    }

    /* Banda E: menos padding, fuente más grande, sin hyphens */
    .CategoryGrid__row--e .WideSupportCard__body,
    .LoadMore__rows .CategoryGrid__row--e .WideSupportCard__body {
      padding: 0.75rem 1rem;
    }

    .CategoryGrid__row--e .WideSupportCard__title,
    .LoadMore__rows .CategoryGrid__row--e .WideSupportCard__title {
      font-size: clamp(1.8rem, 22cqi, 5rem);
      hyphens: none;
    }
  }
</style>
