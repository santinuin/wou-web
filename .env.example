# ── Sanity (públicas — se exponen al browser intencionalmente) ──────────────
PUBLIC_SANITY_PROJECT_ID=tu-project-id
PUBLIC_SANITY_DATASET=production

# ── Sanity API Token (PRIVADO — solo build, nunca al browser) ───────────────
# Crear en sanity.io/manage → API → Tokens → rol "Viewer"
SANITY_API_READ_TOKEN=

# ── Studio (expuestas por `bun run studio`) ─────────────────────────────────
# SANITY_STUDIO_PROJECT_ID=tu-project-id
# SANITY_STUDIO_DATASET=production
