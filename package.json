{
  "name": "wou-web",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "postbuild": "node scripts/patch-wrangler-output.cjs",
    "preview": "astro preview",
    "studio": "cd studio && bun run dev",
    "studio:deploy": "cd studio && bun run deploy",
    "typegen": "sanity typegen generate",
    "check": "astro check && svelte-check --tsconfig ./tsconfig.json",
    "audit": "playwright test tests/audit.spec.ts",
    "audit:report": "playwright test tests/audit.spec.ts --reporter=html"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "latest",
    "@types/matter-js": "^0.20.2",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^4.2.2"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@astrojs/cloudflare": "13",
    "@astrojs/svelte": "^8.0.4",
    "@portabletext/types": "^4.0.2",
    "@sanity/astro": "^3.3.1",
    "@sanity/client": "^7.20.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^5.20.0",
    "astro": "^6.3.1",
    "astro-portabletext": "^0.13.0",
    "groq": "^5.20.0",
    "gsap": "^3.15.0",
    "matter-js": "0.19.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sanity": "^5.20.0",
    "svelte": "^5.55.3"
  }
}
